.badge-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--gradient-page);
  color: var(--color-text-primary);
  transition: background 0.3s ease, color 0.3s ease;
}

.badge-scroll {
  flex: 1;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-sizing: border-box;
}

.badge-summary {
  background: var(--color-surface);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 20rpx 40rpx rgba(15, 23, 42, 0.08);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  text-align: center;
}

.badge-summary__title {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.badge-summary__points {
  font-size: 36rpx;
  font-weight: 700;
}

.badge-summary__current {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
}

.badge-summary__icon {
  font-size: 40rpx;
}

.badge-summary__hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.badge-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.badge-card {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  transition: background 0.3s ease;
  align-items: center;
}

.badge-card--unlocked {
  border-color: rgba(59, 130, 246, 0.4);
  box-shadow: 0 16rpx 36rpx rgba(59, 130, 246, 0.15);
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.12), rgba(147, 197, 253, 0.2));
}

.badge-card__icon {
  font-size: 48rpx;
}

.badge-card__info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.badge-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.badge-card__range,
.badge-card__status {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.badge-card--locked {
  opacity: 0.5;
}

.badge-card--unlocked .badge-card__status {
  color: #16a34a;
}

.badge-card--unlocked {
  box-shadow: 0 16rpx 36rpx rgba(59, 130, 246, 0.15), 0 0 0 1rpx rgba(59, 130, 246, 0.2);
}

/* Dark mode overrides */
.dark .badge-summary {
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.3);
}

.dark .badge-card {
  background: var(--color-surface);
  border-color: var(--color-border);
}

.dark .badge-card--unlocked {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(147, 197, 253, 0.1));
  box-shadow: 0 16rpx 36rpx rgba(59, 130, 246, 0.2), 0 0 12rpx rgba(59, 130, 246, 0.15);
}
