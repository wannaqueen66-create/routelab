<view class="profile-page">
  <rlab-nav title="RouteLab · 我的"></rlab-nav>

  <scroll-view class="profile-scroll" scroll-y>
    <view class="profile-card profile-card--identity">
      <view class="profile-card__avatar">
        <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="profile-card__avatar-placeholder">{{avatarInitial}}</view>
      </view>
      <view class="profile-card__meta">
        <text class="profile-card__name">{{displayName}}</text>
        <text class="profile-card__status">{{shareStatus}}</text>
        <text class="profile-card__id">{{userIdLabel}}</text>
      </view>
    </view>

    <view class="profile-section profile-section--info">
      <view class="section-header">
        <text class="section-title">个人信息</text>
        <text class="section-subtitle">完善资料可获得更准确的运动统计</text>
      </view>
      <view class="info-list">
        <block wx:for="{{personalInfo}}" wx:key="key">
          <view class="info-row">
            <text class="info-row__label">{{item.label}}</text>
            <text class="info-row__value">{{item.value}}</text>
          </view>
        </block>
      </view>
      <button class="btn btn--primary profile-section__cta" bindtap="handleCompleteProfile">
        完善个人信息
      </button>
    </view>

    <view class="profile-section profile-section--settings">
      <view class="settings-row">
        <view class="settings-row__texts">
          <text class="settings-row__title">默认隐私</text>
          <text class="settings-row__desc">默认将新轨迹同步到公共社区</text>
        </view>
        <switch checked="{{defaultPublic}}" bindchange="handleDefaultPrivacyToggle"></switch>
      </view>
      <view class="settings-divider"></view>
      <view class="settings-row settings-row--link" bindtap="handleOpenAbout">
        <view class="settings-row__texts">
          <text class="settings-row__title">关于 RouteLab</text>
          <text class="settings-row__desc">了解应用版本与协议信息</text>
        </view>
        <text class="settings-row__link-text">查看</text>
      </view>
    </view>
  </scroll-view>
</view>
