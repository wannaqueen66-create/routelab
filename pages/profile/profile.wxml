<view class="page">
  <rlab-nav
    title="RouteLab · 偏好设置"
    background="#0f172a"
    color="#ffffff"
  ></rlab-nav>

  <scroll-view class="page__scroll" scroll-y>
    <view class="section">
      <view class="section__title">默认隐私等级</view>
      <picker mode="selector" range="{{privacyOptions}}" range-key="label" value="{{privacyIndex}}" bindchange="handlePrivacyChange">
        <view class="picker">
          <text class="picker__value">{{privacyOptions[privacyIndex].label}}</text>
          <text class="picker__desc">{{privacyOptions[privacyIndex].description}}</text>
        </view>
      </picker>
    </view>

    <view class="section">
      <view class="section__title">常用路线范围</view>
      <picker mode="selector" range="{{campusZones}}" value="{{zoneIndex}}" bindchange="handleZoneChange">
        <view class="picker">
          <text class="picker__value">{{campusZones[zoneIndex]}}</text>
        </view>
      </picker>
    </view>

    <view class="section">
      <view class="section__title">身体参数（估算热量用）</view>
      <view class="field">
        <text class="field__label">体重 (kg)</text>
        <input class="field__input" type="number" placeholder="60" value="{{weight}}" bindinput="handleWeightInput" />
      </view>
    </view>

    <view class="section">
      <view class="section__title">自动同步</view>
      <view class="field field--inline">
        <text class="field__label">联网后自动合并离线轨迹</text>
        <switch checked="{{autoSync}}" bindchange="handleAutoSyncChange" />
      </view>
    </view>

    <view class="actions">
      <button class="btn btn--primary" bindtap="handleSave">保存偏好</button>
      <button class="btn btn--ghost" bindtap="handleClearOffline">清理离线缓存</button>
    </view>

    <view wx:if="{{message}}" class="message">
      <text>{{message}}</text>
    </view>
  </scroll-view>
</view>
