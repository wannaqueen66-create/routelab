.profile-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--gradient-page);
  color: var(--color-text-primary);
  transition: background 0.3s ease, color 0.3s ease;
}

.profile-scroll {
  flex: 1;
  padding: 32rpx 32rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-card {
  background: var(--color-surface);
  border-radius: 24rpx;
  box-shadow: 0 16rpx 30rpx rgba(15, 23, 42, 0.08);
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  align-items: center;
  transition: background 0.3s ease;
}

.profile-card--identity {
  flex-direction: column;
  align-items: stretch;
  gap: 24rpx;
}

.profile-card__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: var(--color-surface-muted);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-card__avatar image {
  width: 100%;
  height: 100%;
}

.profile-card__avatar-placeholder {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
}

.profile-card__name {
  font-size: 36rpx;
  font-weight: 700;
}

.profile-card__status {
  font-size: 26rpx;
  color: var(--color-primary);
}

.profile-card__id {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.profile-card__header {
  width: 100%;
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.profile-card__info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.profile-card__identity {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.profile-card__points {
  min-width: 170rpx;
  padding: 12rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(37, 99, 235, 0.08);
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  color: var(--color-primary-strong);
  flex-shrink: 0;
}

.profile-card__points-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.profile-card__points-label {
  font-size: 24rpx;
}

.profile-card__points-sub {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.profile-card__achievements {
  width: 100%;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(15, 23, 42, 0.04);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-card__points-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.profile-card__points-row-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.profile-card__points-row-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.profile-card__badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.profile-card__badge-icon {
  font-size: 36rpx;
}

.profile-card__badge-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.profile-card__badge-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.profile-card__badge-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.profile-card__hint-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.profile-card__badge-hint {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.profile-card__badge-cta {
  font-size: 24rpx;
  color: var(--color-primary);
}

.profile-section {
  background: var(--color-surface);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 25rpx rgba(15, 23, 42, 0.06);
  transition: background 0.3s ease;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1px solid var(--color-border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-row__label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.info-row__value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.profile-section__cta {
  margin-top: 8rpx;
}

.profile-section--settings {
  gap: 12rpx;
}

.settings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.settings-row__texts {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.settings-row__title {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.settings-row__desc {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.settings-divider {
  height: 1px;
  background: var(--color-border);
}

.settings-row__link-text {
  font-size: 26rpx;
  color: var(--color-primary);
}

/* Dark mode overrides */
.dark .profile-card {
  box-shadow: 0 16rpx 30rpx rgba(0, 0, 0, 0.3);
}

.dark .profile-section {
  box-shadow: 0 12rpx 25rpx rgba(0, 0, 0, 0.3);
}

.dark .profile-card__achievements {
  background: rgba(255, 255, 255, 0.06);
}

.dark .profile-card__points {
  background: rgba(37, 99, 235, 0.15);
}
