.profile-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f4f6fb 0%, #e9ecf7 100%);
  color: #0f172a;
}

.profile-scroll {
  flex: 1;
  padding: 32rpx 32rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 30rpx rgba(15, 23, 42, 0.08);
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.profile-card__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #e2e8f0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-card__avatar image {
  width: 100%;
  height: 100%;
}

.profile-card__avatar-placeholder {
  font-size: 36rpx;
  font-weight: 600;
  color: #475569;
}

.profile-card__meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.profile-card__name {
  font-size: 36rpx;
  font-weight: 700;
}

.profile-card__status {
  font-size: 26rpx;
  color: #2563eb;
}

.profile-card__id {
  font-size: 24rpx;
  color: #94a3b8;
}

.profile-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 25rpx rgba(15, 23, 42, 0.06);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
}

.section-subtitle {
  font-size: 24rpx;
  color: #94a3b8;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1px solid rgba(148, 163, 184, 0.2);
}

.info-row:last-child {
  border-bottom: none;
}

.info-row__label {
  font-size: 26rpx;
  color: #64748b;
}

.info-row__value {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
}

.profile-section__cta {
  margin-top: 8rpx;
}

.profile-section--settings {
  gap: 12rpx;
}

.settings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.settings-row__texts {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.settings-row__title {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
}

.settings-row__desc {
  font-size: 24rpx;
  color: #94a3b8;
}

.settings-divider {
  height: 1px;
  background: rgba(148, 163, 184, 0.25);
}

.settings-row__link-text {
  font-size: 26rpx;
  color: #2563eb;
}
