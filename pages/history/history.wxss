.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f8fafc;
}

.filter {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.05);
  z-index: 2;
}

.filter__item {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #475569;
  background: #e2e8f0;
}

.filter__item--active {
  background: #38bdf8;
  color: #0f172a;
  font-weight: 600;
}

.list {
  flex: 1;
  padding: 24rpx 32rpx 56rpx;
  box-sizing: border-box;
}

.empty {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  color: #475569;
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.08);
}

.empty__title {
  font-size: 32rpx;
  font-weight: 600;
}

.empty__desc {
  font-size: 26rpx;
  margin: 16rpx 0 24rpx;
}

.empty .btn {
  background: #38bdf8;
  color: #0f172a;
  border-radius: 999rpx;
}

.route-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.05);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.route-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.route-card__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.route-card__privacy {
  font-size: 24rpx;
  color: #38bdf8;
}

.route-card__meta {
  display: flex;
  gap: 10rpx;
  font-size: 24rpx;
  color: #475569;
  align-items: center;
}

.route-card__meta--campus {
  font-size: 24rpx;
  color: #64748b;
}

.route-card__footer {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #64748b;
}

.route-card__extra {
  font-size: 22rpx;
  color: #94a3b8;
}

.route-card__date {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #94a3b8;
}
