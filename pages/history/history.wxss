.page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(
      --gradient-page,
      linear-gradient(180deg, var(--color-page-bg) 0%, var(--color-page-bg-strong) 100%)
    );
    color: var(--color-text-primary);
    transition: background 0.3s ease, color 0.3s ease;
  }
  
  .sync-status-bar {
    margin: 16rpx 32rpx 0;
    padding: 14rpx 18rpx;
    border-radius: 16rpx;
    background: rgba(47, 107, 255, 0.1);
    color: var(--color-primary);
    font-size: 24rpx;
  }

  .sync-status-error {
    margin-top: 10rpx;
    padding: 10rpx 12rpx;
    border-radius: 12rpx;
    background: rgba(220, 38, 38, 0.12);
    color: #991b1b;
    font-size: 22rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12rpx;
  }

  .sync-status-error__texts {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4rpx;
  }

  .sync-status-error__hint {
    font-size: 20rpx;
    color: #7f1d1d;
  }

  .sync-status-error__retry {
    margin: 0;
    padding: 0 16rpx;
    height: 48rpx;
    line-height: 48rpx;
    font-size: 22rpx;
    border-radius: 999rpx;
    background: rgba(255, 255, 255, 0.72);
    color: #991b1b;
  }

  .sync-status-error__retry::after {
    display: none;
  }

  .filter {
    display: flex;
    align-items: center;
    gap: 16rpx;
    padding: 28rpx 32rpx;
    box-sizing: border-box;
    background: var(--color-surface);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    margin: 16rpx 32rpx 0;
  }
  
  .filter__item {
    padding: 16rpx 28rpx;
    border-radius: 999rpx;
    background: rgba(47, 107, 255, 0.08);
    color: var(--color-text-secondary);
    font-size: 26rpx;
  }
  
  .filter__item--active {
    background: rgba(47, 107, 255, 0.16);
    color: var(--color-primary);
    box-shadow: 0 12rpx 26rpx rgba(47, 107, 255, 0.2);
  }
  
  .filter__sync {
    margin-left: auto;
    padding: 16rpx 28rpx;
    border-radius: 18rpx;
    font-size: 26rpx;
    color: var(--color-primary);
    background: rgba(47, 107, 255, 0.08);
    border: 1px solid rgba(47, 107, 255, 0.2);
  }
  
  .filter__sync::after {
    display: none;
  }
  
  .list {
    flex: 1;
    padding: 0 32rpx 32rpx;
    box-sizing: border-box;
  }

  .list-load-more {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 24rpx;
    padding: 8rpx 0 20rpx;
  }

  .list-load-more--end {
    opacity: 0.72;
  }

  .history-skeleton {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
    padding-top: 8rpx;
  }

  .history-skeleton__card {
    border-radius: var(--radius-card);
    border: 1rpx solid var(--color-border-soft);
    background: var(--color-surface);
    padding: 22rpx;
    display: flex;
    flex-direction: column;
    gap: 12rpx;
  }

  .history-skeleton__line {
    height: 22rpx;
    border-radius: 10rpx;
    background: linear-gradient(90deg, rgba(226, 232, 240, 0.8), rgba(241, 245, 249, 0.95), rgba(226, 232, 240, 0.8));
  }

  .history-skeleton__line--title {
    width: 58%;
    height: 28rpx;
  }

  .history-skeleton__line--meta {
    width: 80%;
  }

  .history-skeleton__line--path {
    width: 94%;
  }
  
  .empty {
    margin-top: 120rpx;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 24rpx;
    color: var(--color-text-secondary);
  }
  
  .empty__title {
    font-size: 34rpx;
    font-weight: 600;
    color: var(--color-text-primary);
  }
  
  .empty__desc {
    font-size: 26rpx;
    color: var(--color-text-secondary);
    line-height: 1.5;
    padding: 0 48rpx;
  }
  
  .route-card {
    background: var(--color-surface);
    border-radius: 28rpx;
    padding: 28rpx;
    margin-bottom: 24rpx;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 16rpx;
  }
  
.route-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.route-card__title {
  font-size: 32rpx;
  font-weight: 600;
}

.route-card__title-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.route-card__status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: rgba(249, 115, 22, 0.15);
  color: #f97316;
}

.route-card__status-icon {
  font-size: 26rpx;
}

.route-card__privacy {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}
  
  .route-card__meta,
  .route-card__footer,
  .route-card__path,
  .route-card__date {
    display: flex;
    gap: 12rpx;
    font-size: 24rpx;
    color: var(--color-text-secondary);
  }
  
  .route-card__path {
    align-items: center;
    font-size: 26rpx;
    color: var(--color-text-primary);
  }
  
  .route-card__arrow {
    opacity: 0.65;
  }
  
  .route-card__extra {
    font-size: 22rpx;
    color: var(--color-text-secondary);
    display: inline-flex;
    align-items: center;
    gap: 8rpx;
  }

  .route-card__photo-thumb {
    width: 30rpx;
    height: 30rpx;
    border-radius: 8rpx;
    background: rgba(148, 163, 184, 0.18);
  }
  
  .route-card__sync-error {
    margin-top: 4rpx;
    border-radius: 14rpx;
    background: rgba(220, 38, 38, 0.08);
    color: #991b1b;
    padding: 10rpx 12rpx;
    font-size: 22rpx;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
  }

  .route-card__sync-error-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10rpx;
  }

  .route-card__sync-error-body {
    display: flex;
    flex-direction: column;
    gap: 6rpx;
    color: #7f1d1d;
  }

  .route-card__date {
    font-size: 22rpx;
    color: var(--color-text-tertiary);
  }

  /* ── Smooth transitions ── */
  .filter,
  .route-card,
  .history-skeleton__card {
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  /* ── Dark mode overrides ── */
  .dark .history-skeleton__line {
    background: linear-gradient(90deg, rgba(51, 65, 85, 0.6), rgba(30, 41, 59, 0.8), rgba(51, 65, 85, 0.6));
  }

  .dark .sync-status-error {
    background: rgba(220, 38, 38, 0.18);
    color: #fca5a5;
  }

  .dark .sync-status-error__hint {
    color: #fca5a5;
  }

  .dark .sync-status-error__retry {
    background: rgba(255, 255, 255, 0.1);
    color: #fca5a5;
  }

  .dark .route-card__sync-error {
    background: rgba(220, 38, 38, 0.15);
    color: #fca5a5;
  }

  .dark .route-card__sync-error-body {
    color: #fca5a5;
  }
