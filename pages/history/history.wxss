.page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(
      --gradient-page,
      linear-gradient(180deg, var(--color-page-bg) 0%, var(--color-page-bg-strong) 100%)
    );
    color: var(--color-text-primary);
  }
  
  .filter {
    display: flex;
    align-items: center;
    gap: 16rpx;
    padding: 28rpx 32rpx;
    box-sizing: border-box;
    background: var(--color-surface);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    margin: 16rpx 32rpx 0;
  }
  
  .filter__item {
    padding: 16rpx 28rpx;
    border-radius: 999rpx;
    background: rgba(47, 107, 255, 0.08);
    color: var(--color-text-secondary);
    font-size: 26rpx;
  }
  
  .filter__item--active {
    background: rgba(47, 107, 255, 0.16);
    color: var(--color-primary);
    box-shadow: 0 12rpx 26rpx rgba(47, 107, 255, 0.2);
  }
  
  .filter__sync {
    margin-left: auto;
    padding: 16rpx 28rpx;
    border-radius: 18rpx;
    font-size: 26rpx;
    color: var(--color-primary);
    background: rgba(47, 107, 255, 0.08);
    border: 1px solid rgba(47, 107, 255, 0.2);
  }
  
  .filter__sync::after {
    display: none;
  }
  
  .list {
    flex: 1;
    padding: 0 32rpx 32rpx;
    box-sizing: border-box;
  }
  
  .empty {
    margin-top: 120rpx;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 24rpx;
    color: var(--color-text-secondary);
  }
  
  .empty__title {
    font-size: 34rpx;
    font-weight: 600;
    color: var(--color-text-primary);
  }
  
  .empty__desc {
    font-size: 26rpx;
    color: var(--color-text-secondary);
    line-height: 1.5;
    padding: 0 48rpx;
  }
  
  .route-card {
    background: var(--color-surface);
    border-radius: 28rpx;
    padding: 28rpx;
    margin-bottom: 24rpx;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 16rpx;
  }
  
  .route-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .route-card__title {
    font-size: 32rpx;
    font-weight: 600;
  }
  
  .route-card__privacy {
    font-size: 24rpx;
    color: var(--color-text-secondary);
  }
  
  .route-card__meta,
  .route-card__footer,
  .route-card__path,
  .route-card__date {
    display: flex;
    gap: 12rpx;
    font-size: 24rpx;
    color: var(--color-text-secondary);
  }
  
  .route-card__path {
    align-items: center;
    font-size: 26rpx;
    color: var(--color-text-primary);
  }
  
  .route-card__arrow {
    opacity: 0.65;
  }
  
  .route-card__extra {
    font-size: 22rpx;
    color: var(--color-text-secondary);
  }
  
  .route-card__date {
    font-size: 22rpx;
    color: var(--color-text-tertiary);
  }
