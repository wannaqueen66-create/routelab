<view class="page">
  <rlab-nav
    title="RouteLab · 历史轨迹"
  ></rlab-nav>

  <view class="sync-status-bar">
    <text>{{syncSummaryText}}</text>
    <view class="sync-status-error" wx:if="{{syncErrorText}}">
      <text>{{syncErrorText}}</text>
      <button class="sync-status-error__retry" loading="{{syncing}}" bindtap="handleForceSyncTap">重试同步</button>
    </view>
  </view>

  <view class="filter">
    <block wx:for="{{filterTabs}}" wx:key="key">
      <view
        class="filter__item {{activeFilter === item.key ? 'filter__item--active' : ''}}"
        data-key="{{item.key}}"
        bindtap="handleFilterTap"
      >
        {{item.label}}
      </view>
    </block>
    <button class="filter__sync" loading="{{syncing}}" bindtap="handleSyncTap">
      {{syncing ? '同步中...' : '同步云端'}}
    </button>
  </view>

  <scroll-view
    class="list"
    scroll-y
    enable-back-to-top
    lower-threshold="180"
    bindscrolltolower="handleLoadMore"
  >
    <view wx:if="{{historyLoading}}" class="history-skeleton">
      <view class="history-skeleton__card" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="history-skeleton__line history-skeleton__line--title"></view>
        <view class="history-skeleton__line history-skeleton__line--meta"></view>
        <view class="history-skeleton__line history-skeleton__line--path"></view>
      </view>
    </view>
    <view wx:elif="{{empty}}" class="empty">
      <text class="empty__title">暂无轨迹记录</text>
      <text class="empty__desc">开启一次记录，RouteLab 会自动识别起点终点并生成统计。</text>
      <button class="btn btn--primary" open-type="navigateTo" url="/pages/record/record">马上开始</button>
    </view>
    <block wx:else>
      <block wx:for="{{routes}}" wx:key="id">
        <view
          class="route-card"
          data-id="{{item.id}}"
          bindtap="handleRouteTap"
          bindlongpress="handleRouteLongPress"
        >
          <view class="route-card__header">
            <view class="route-card__title-group">
              <text class="route-card__title">{{item.title}}</text>
              <view class="route-card__status" wx:if="{{item.syncPending}}">
                <text class="route-card__status-icon">🔄</text>
                <text class="route-card__status-text">{{item.syncStatusLabel}}</text>
              </view>
            </view>
            <text class="route-card__privacy">{{item.privacyLabel}}</text>
          </view>
          <view class="route-card__meta">
            <text>{{item.distanceText}}</text>
            <text>·</text>
            <text>{{item.durationText}}</text>
            <text>·</text>
            <text>{{item.caloriesText}}</text>
          </view>
          <view class="route-card__path">
            <text>{{item.startLabel}}</text>
            <text class="route-card__arrow">→</text>
            <text>{{item.endLabel}}</text>
          </view>
          <view class="route-card__footer">
            <text>{{item.activityLabel}}</text>
            <text>{{item.timeRange}}</text>
          </view>
          <view class="route-card__extra" wx:if="{{item.photosCount}}">
            <image
              class="route-card__photo-thumb"
              src="{{item.previewPhoto || ''}}"
              mode="aspectFill"
              lazy-load="true"
              wx:if="{{item.previewPhoto}}"
            />
            <text>{{item.photosCount}} 张打卡照片</text>
          </view>
          <view class="route-card__date">
            <text>{{item.startDate}}</text>
          </view>
        </view>
      </block>
      <view class="list-load-more" wx:if="{{hasMore}}">
        <text>上拉加载更多轨迹…</text>
      </view>
      <view class="list-load-more list-load-more--end" wx:else>
        <text>已显示全部轨迹</text>
      </view>
    </block>
  </scroll-view>
</view>
