<view class="page">
  <rlab-nav
    title="RouteLab · 开始记录"
    background="#101735"
    color="#ffffff"
  ></rlab-nav>

  <scroll-view class="page__scroll" scroll-y enable-back-to-top>
    <view class="map-wrapper" bindtap="handleMapTap">
      <map
        id="routeMap"
        longitude="{{centerLongitude}}"
        latitude="{{centerLatitude}}"
        scale="16"
        show-location="true"
        enable-satellite="false"
        show-scale="true"
        style="width: 100%; height: 520rpx;"
        markers="{{markers}}"
        polyline="{{polyline}}"
      ></map>
      <view class="map-overlay" wx:if="{{!tracking}}">
        <text>点击 START，先锁定起点再开始记录</text>
      </view>
    </view>

    <view class="section section--light">
      <view class="section__head">
        <text class="section__title">出行方式</text>
      </view>
      <view class="activity-selector">
        <block wx:for="{{activityOptions}}" wx:key="key">
          <view
            class="activity-selector__item {{activityIndex === index ? 'activity-selector__item--active' : ''}}"
            data-index="{{index}}"
            bindtap="handleActivitySelect"
          >
            <text class="activity-selector__label">{{item.label}}</text>
          </view>
        </block>
      </view>
      <text class="activity-selector__desc">{{activityDescription}}</text>
    </view>

    <view class="section section--light">
      <view class="section__head">
        <text class="section__title">路线节点</text>
      </view>
      <view class="location-row">
        <text class="location-row__label">起点</text>
        <picker
          mode="multiSelector"
          range="{{startPickerRange}}"
          value="{{startPickerValue}}"
          disabled="{{tracking || startSelectionLocked}}"
          bindchange="handleStartPickerChange"
          bindcolumnchange="handleStartPickerColumnChange"
        >
          <view class="picker picker--surface {{tracking || startSelectionLocked ? 'picker--disabled' : ''}} {{startSelectionLocked ? '' : 'picker--pending'}}">
            <view class="picker__value-row">
              <text class="picker__value">{{startSelectedText}}</text>
              <text class="picker__status" wx:if="{{startSelectionLocked}}">已锁定</text>
            </view>
            <text class="picker__hint" wx:if="{{tracking}}">录制中不可修改</text>
            <text class="picker__hint" wx:elif="{{startSelectionLocked}}">停止记录后可重新选择</text>
            <text class="picker__hint" wx:else>点击选择起点位置</text>
          </view>
        </picker>
      </view>
      <view class="location-row">
        <text class="location-row__label">终点</text>
        <picker
          mode="multiSelector"
          range="{{endPickerRange}}"
          value="{{endPickerValue}}"
          bindchange="handleEndPickerChange"
          bindcolumnchange="handleEndPickerColumnChange"
        >
          <view class="picker picker--surface">
            <text class="picker__value">{{endSelectedText}}</text>
            <text class="picker__hint">提交前可随时调整</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="section stats">
      <view class="stat-card">
        <text class="stat-card__label">已用时</text>
        <text class="stat-card__value">{{durationText}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-card__label">累计里程</text>
        <text class="stat-card__value">{{distanceText}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-card__label">{{currentActivityKey === 'ride' ? '平均速度' : '实时配速'}}</text>
        <text class="stat-card__value">{{speedText}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-card__label">估算热量</text>
        <text class="stat-card__value">{{caloriesText}}</text>
      </view>
      <view class="stat-card stat-card--wide">
        <text class="stat-card__label">估算步数</text>
        <text class="stat-card__value">{{stepsText}}</text>
      </view>
    </view>

    <view class="controls">
      <button wx:if="{{!tracking}}" class="btn btn--primary" bindtap="handleStart">START</button>
      <view wx:elif="{{tracking}}" class="controls__group">
        <button wx:if="{{!paused}}" class="btn btn--ghost" bindtap="handlePause">PAUSE</button>
        <button wx:if="{{paused}}" class="btn btn--secondary" bindtap="handleResume">RESUME</button>
        <button class="btn btn--danger" bindtap="handleStop">FINISH</button>
      </view>
      <view class="controls__hint" wx:if="{{paused}}">暂停时不会记录轨迹</view>
    </view>

    <view class="section section--light">
      <view class="section__head">
        <text class="section__title">打卡照片</text>
        <button class="link-button" size="mini" bindtap="handleAddPhoto">添加照片</button>
      </view>
      <view class="photo-grid" wx:if="{{photos.length}}">
        <block wx:for="{{photos}}" wx:key="path">
          <view class="photo-grid__item">
            <image
              class="photo-grid__image"
              src="{{item.path}}"
              mode="aspectFill"
              data-index="{{index}}"
              bindtap="handlePreviewPhoto"
            />
            <view class="photo-grid__remove" data-index="{{index}}" bindtap="handleRemovePhoto">×</view>
          </view>
          <textarea
            class="photo-grid__note"
            placeholder="写下此刻的备注或心情"
            value="{{item.note}}"
            data-index="{{index}}"
            bindinput="handlePhotoNoteInput"
          ></textarea>
        </block>
      </view>
      <view class="photo-section__empty" wx:if="{{!photos.length}}">
        <text>途中拍照或上传，为本次路线留影</text>
      </view>
    </view>

    <view class="section section--surface">
      <view class="form-row">
        <text class="form-label">隐私等级</text>
        <picker
          mode="selector"
          value="{{privacyIndex}}"
          range="{{privacyOptions}}"
          range-key="label"
          bindchange="handlePrivacyChange"
        >
          <view class="picker picker--input">
            <text class="picker__value">{{privacyOptions[privacyIndex].label}}</text>
            <text class="picker__hint">{{privacyOptions[privacyIndex].description}}</text>
          </view>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">路线名称</text>
        <input
          class="input"
          placeholder="如：午后环校骑行"
          value="{{title}}"
          bindinput="handleTitleInput"
        />
      </view>
      <view class="form-row">
        <text class="form-label">备注</text>
        <textarea
          class="textarea"
          placeholder="记录天气、同行伙伴或心情"
          value="{{note}}"
          bindinput="handleNoteInput"
          auto-height
        ></textarea>
      </view>
    </view>

    <view class="shortcut">
      <button class="btn btn--ghost" bindtap="handleViewHistory">历史记录</button>
      <button class="btn btn--ghost" bindtap="handleOpenSettings">偏好设置</button>
    </view>
  </scroll-view>
</view>