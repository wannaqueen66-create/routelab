<view class="record-page">
  <view class="map-region">
    <view class="record-nav">
      <rlab-nav
        background="transparent"
        color="#1F2329"
        home-button="{{false}}"
        custom-back="{{true}}"
        bindback="handleNavigateBackConfirm"
      ></rlab-nav>
    </view>
    <map
      id="routeMap"
      class="record-map"
      longitude="{{centerLongitude}}"
      latitude="{{centerLatitude}}"
      scale="16"
      show-location="{{true}}"
    enable-satellite="false"
    show-scale="true"
    markers="{{markers}}"
    polyline="{{polyline}}"
    include-points="{{includePoints}}"
    bindtap="handleMapTap"
    bindregionchange="handleMapRegionChange"
    ></map>

    <view class="map-tip" wx:if="{{!tracking && !hasRoutePoints}}">
      <text>点击"开始记录"即可生成第一条校园轨迹</text>
    </view>

    <button
      class="locate-button {{locateAnimationActive ? 'locate-button--active' : ''}}"
      bindtap="handleLocateTap"
      hover-class="is-active"
    >
      <text class="locate-button__icon">📍</text>
    </button>
  </view>

  <view class="sheet-container">
    <view class="record-sheet">
      <view class="record-sheet__grabber"></view>

      <view class="metrics-grid">
        <view class="metric">
          <view class="metric__icon">⏱️</view>
          <view class="metric__texts">
            <text class="metric__label">用时</text>
            <text class="metric__value">{{durationText}}</text>
          </view>
        </view>
        <view class="metric">
          <view class="metric__icon">📏</view>
          <view class="metric__texts">
            <text class="metric__label">距离</text>
            <text class="metric__value">{{distanceText}}</text>
          </view>
        </view>
        <view class="metric">
          <view class="metric__icon">⚡</view>
          <view class="metric__texts">
            <text class="metric__label">实时配速</text>
            <text class="metric__value">{{speedText}}</text>
          </view>
        </view>
        <view class="metric">
          <view class="metric__icon">🔥</view>
          <view class="metric__texts">
            <text class="metric__label">估算热量</text>
            <text class="metric__value">{{caloriesText}}</text>
          </view>
        </view>
      </view>

      <view class="sheet-meta">
        <view class="status-chips">
          <view class="status-chip status-chip--signal {{signalQualityLabel === '定位较弱' ? 'status-chip--warn' : ''}}">
            {{signalQualityLabel}}
          </view>
          <view class="status-chip status-chip--sync">{{syncHintText}}</view>
        </view>
        <view class="meta-inline">
          <view
            class="meta-inline__cell meta-inline__cell--action {{tracking ? '' : 'meta-inline__cell--disabled'}}"
            bindtap="handleActivityCellTap"
          >
            <view class="meta-inline__texts">
              <text class="meta-inline__label-text">行进方式</text>
              <view class="meta-inline__value-wrap">
                <text class="meta-inline__value">{{activityLabel}}</text>
                <text class="meta-inline__badge" wx:if="{{activityManual}}">手动</text>
              </view>
            </view>
            <text class="meta-inline__hint" wx:if="{{!tracking}}">识别中</text>
          </view>
          <view class="meta-inline__divider"></view>
          <view class="meta-inline__cell meta-inline__cell--action" bindtap="handleOpenPurposePicker">
            <view class="meta-inline__texts">
              <text class="meta-inline__label-text">出行目的</text>
              <text class="meta-inline__value">{{purposeSelectionLabel}}</text>
            </view>
            <text class="meta-inline__hint">可调整</text>
          </view>
        </view>

        <view class="meta-item meta-item--toggle">
          <view class="meta-item__icon">💡</view>
          <text class="meta-item__label meta-item__label--inline">保持屏幕常亮</text>
          <switch
            class="meta-item__switch"
            checked="{{keepScreenOnPreferred}}"
            bindchange="handleKeepScreenToggle"
            disabled="{{!keepScreenSupported}}"
          ></switch>
        </view>
      </view>

      <view class="sheet-controls" wx:if="{{!tracking}}">
        <button class="btn btn--primary" bindtap="handleStart">开始记录</button>
      </view>

      <view class="sheet-controls sheet-controls--dual" wx:elif="{{tracking && !paused}}">
        <button class="btn btn--ghost" bindtap="handlePause">暂停</button>
        <button class="btn btn--danger" bindtap="handleFinishPrompt">结束</button>
      </view>

      <view class="sheet-controls sheet-controls--dual" wx:else>
        <button class="btn btn--primary" bindtap="handleResume">继续</button>
        <button class="btn btn--danger" bindtap="handleFinishPrompt">结束</button>
      </view>
    </view>
  </view>

  <view
    class="purpose-picker-overlay"
    wx:if="{{purposePickerVisible}}"
    catchtouchmove="true"
  >
    <view class="purpose-picker">
      <view class="purpose-picker__header">
        <text class="purpose-picker__title">你这次是去做什么运动？</text>
        <text class="purpose-picker__subtitle">用于分析不同路线的运动偏好</text>
      </view>
      <view class="purpose-picker__grid">
        <block wx:for="{{purposeOptions}}" wx:key="key">
          <view
            class="purpose-picker__item {{purposePendingKey === item.key ? 'purpose-picker__item--active' : ''}}"
            data-key="{{item.key}}"
            bindtap="handlePurposeTap"
          >
            <view class="purpose-picker__item-icon">
              <text>{{item.icon}}</text>
            </view>
            <text class="purpose-picker__item-label">{{item.label}}</text>
          </view>
        </block>
      </view>
      <view class="purpose-picker__note">
        <text>
          {{tracking ? purposeNoteTracking : purposeNoteIdle}}
        </text>
      </view>
      <view class="purpose-picker__actions">
        <button class="btn btn--ghost" bindtap="handlePurposeCancel">取消</button>
        <button class="btn btn--primary" bindtap="handlePurposeConfirm">
          {{tracking ? purposeConfirmTracking : purposeConfirmIdle}}
        </button>
      </view>
    </view>
  </view>

  <view
    class="finish-sheet-overlay"
    wx:if="{{finishSheetVisible}}"
    catchtouchmove="true"
  >
    <view class="finish-sheet">
      <view class="finish-sheet__header">
        <text class="finish-sheet__title">完成记录</text>
        <text class="finish-sheet__subtitle">补充路线名称、备注与隐私设置</text>
      </view>
      <view class="finish-sheet__body">
        <view class="finish-field">
          <text class="finish-field__label">路线名称</text>
          <input
            class="finish-field__input"
            placeholder="如：午后环校骑行"
            value="{{title}}"
            bindinput="handleTitleInput"
          />
        </view>
        <view class="finish-field finish-field--textarea">
          <text class="finish-field__label">备注</text>
          <textarea
            class="finish-field__textarea"
            placeholder="记录天气、同行伙伴或心情"
            value="{{note}}"
            bindinput="handleNoteInput"
            auto-height
          ></textarea>
        </view>
        <view class="finish-field">
          <text class="finish-field__label">隐私等级</text>
          <radio-group
            class="finish-privacy"
            bindchange="handlePrivacyChange"
            value="{{privacyOptions[privacyIndex].key}}"
          >
            <label
              wx:for="{{privacyOptions}}"
              wx:key="key"
              class="finish-privacy__item"
            >
              <radio value="{{item.key}}" checked="{{privacyOptions[privacyIndex].key === item.key}}" />
              <text>{{item.label}}</text>
            </label>
          </radio-group>
        </view>
        <view class="finish-field">
          <text class="finish-field__label">打卡照片</text>
          <text class="finish-field__hint">💡 拍照打卡可获得双倍积分！</text>
          <view class="finish-photo__actions">
            <button class="btn btn--camera" bindtap="handleAddPhoto">📷 拍摄</button>
            <button class="btn btn--ghost finish-photo__retry-all" loading="{{batchRetrying}}" bindtap="handleRetryAllPhotos">🔁 重传失败图片</button>
          </view>
          <view class="finish-photo__batch-progress" wx:if="{{batchRetryProgressText}}">
            <text>{{batchRetryProgressText}}</text>
          </view>
          <view class="finish-photo__grid" wx:if="{{photos.length}}">
            <block wx:for="{{photos}}" wx:key="path">
              <view class="finish-photo__item">
                <image src="{{item.path}}" mode="aspectFill" bindtap="handlePreviewPhoto" data-index="{{index}}" />
                <view
                  class="finish-photo__remove"
                  data-index="{{index}}"
                  bindtap="handleRemovePhoto"
                >
                  ✕
                </view>
                <view class="finish-photo__state" wx:if="{{item.uploadError}}">
                  <text class="finish-photo__state-text">上传失败</text>
                  <text class="finish-photo__state-retry" data-index="{{index}}" bindtap="handleRetryPhoto">重试</text>
                </view>
              </view>
            </block>
          </view>
        </view>
      </view>
      <view class="finish-sheet__actions">
        <button class="btn btn--ghost" bindtap="handleFinishCancel">取消</button>
        <button
          class="btn btn--primary"
          bindtap="handleFinishSave"
          loading="{{uploading}}"
          disabled="{{uploading}}"
        >
          保存
        </button>
      </view>
    </view>
  </view>

  <view
    class="reward-modal-overlay"
    wx:if="{{rewardModalVisible && rewardSummary}}"
    catchtouchmove="true"
  >
    <view class="reward-modal">
      <text class="reward-modal__title">{{rewardSummary.title}}</text>
      <view class="reward-modal__stats">
        <view class="reward-modal__row">
          <text class="reward-modal__label">本次运动</text>
          <text class="reward-modal__value">{{rewardSummary.distanceText}}</text>
        </view>
        <view class="reward-modal__row">
          <text class="reward-modal__label">用时</text>
          <text class="reward-modal__value">{{rewardSummary.durationText}}</text>
        </view>
        <view class="reward-modal__row" wx:if="{{rewardSummary.hasPhoto}}">
          <text class="reward-modal__label">📸 已上传</text>
          <text class="reward-modal__value">{{rewardSummary.photoCount}} 张照片</text>
        </view>
      </view>
      <view class="reward-modal__points">
        <text class="reward-modal__points-label">获得积分</text>
        <text class="reward-modal__points-gain">+{{rewardSummary.gainedPoints}}</text>
        <text class="reward-modal__points-stars">{{rewardSummary.starIcons}}</text>
      </view>
      <view class="reward-modal__total">
        当前总积分：<text class="reward-modal__total-value">{{rewardSummary.totalPoints}}</text>
      </view>
      <button class="btn btn--primary reward-modal__cta" bindtap="handleRewardConfirm">
        确定
      </button>
    </view>
  </view>

  <view
    class="location-permission-overlay"
    wx:if="{{!locationAuthorized && showLocationPrompt}}"
    catchtouchmove="true"
  >
    <view class="location-permission-dialog">
      <view class="location-permission-dialog__badge">RouteLab</view>
      <view class="location-permission-dialog__title">
        需要获取定位权限
      </view>
      <view class="location-permission-dialog__desc">
        RouteLab 需要持续定位以绘制轨迹、统计里程以及提供天气建议，请允许使用位置信息。
      </view>
      <view class="location-permission-dialog__actions">
        <button
          class="location-permission-dialog__primary"
          type="primary"
          loading="{{locationPromptPending}}"
          disabled="{{locationPromptPending}}"
          bindtap="handleLocationPermissionAuthorize"
        >
          立即授权
        </button>
        <button
          class="location-permission-dialog__secondary"
          loading="{{locationPromptPending}}"
          disabled="{{locationPromptPending}}"
          bindtap="handleLocationPermissionOpenSettings"
        >
          打开设置
        </button>
      </view>
      <view class="location-permission-dialog__tip">
        若已拒绝，请前往 设置 → 隐私 → 定位 重新开启
      </view>
    </view>
  </view>
</view>
