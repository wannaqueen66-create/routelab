.record-page {
  min-height: 100vh;
  background: var(--color-page-bg);
  color: var(--color-text-primary);
  display: flex;
  flex-direction: column;
  -webkit-overflow-scrolling: touch;
}

.map-region {
  position: relative;
  flex: 0 0 58vh;
  max-height: 70vh;
  overflow: hidden;
  z-index: 0;
}

.record-map {
  width: 100%;
  height: 100%;
}

.record-nav {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  pointer-events: none;
}

.record-nav rlab-nav {
  pointer-events: auto;
}

.map-tip {
  position: absolute;
  top: 64rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(15, 23, 42, 0.6);
  border: 1px solid rgba(15, 23, 42, 0.12);
  color: #ffffff;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  backdrop-filter: blur(12rpx);
}

.sheet-container {
  flex: 1;
  width: 100%;
  margin-top: -48rpx;
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  background: var(--color-page-bg);
}

.record-sheet {
  margin: 0 24rpx;
  padding: 28rpx 32rpx;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background: var(--record-sheet-bg, rgba(255, 255, 255, 0.94));
  backdrop-filter: blur(20rpx);
  border-radius: 40rpx;
  transition: background 0.3s ease, color 0.3s ease;
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.12);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-sheet__grabber {
  width: 100rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.4);
  margin: 0 auto;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.metric {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.06);
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.metric__icon {
  font-size: 32rpx;
}

.metric__texts {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.metric__label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.metric__value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.2;
  -webkit-font-smoothing: antialiased;
}

.sheet-meta {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.status-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.status-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--chip-blue-text, #1e3a8a);
  background: var(--chip-blue-bg, rgba(30, 64, 175, 0.12));
}

.status-chip--warn {
  color: var(--chip-warn-text, #b45309);
  background: var(--chip-warn-bg, rgba(245, 158, 11, 0.2));
}

.status-chip--sync {
  color: var(--chip-sync-text, #334155);
  background: var(--chip-sync-bg, rgba(148, 163, 184, 0.22));
}

.meta-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.05);
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.meta-inline__cell {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-inline__hint {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.meta-inline__cell--static .meta-inline__value {
  color: var(--color-text-primary);
}

.meta-inline__cell--action {
  justify-content: flex-start;
  gap: 12rpx;
}

.meta-inline__cell--disabled {
  opacity: 0.65;
}

.meta-inline__label-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.meta-inline__value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.meta-inline__texts {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.meta-inline__value-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-inline__badge {
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--color-primary);
  background: rgba(37, 99, 235, 0.12);
}

.meta-inline__divider {
  width: 1px;
  height: 36rpx;
  margin: 0 16rpx;
  background: rgba(148, 163, 184, 0.4);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.05);
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.meta-item__icon {
  font-size: 32rpx;
}

.meta-item__label {
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.meta-item--toggle {
  justify-content: space-between;
}

.meta-item__label--inline {
  flex: 1;
}

.meta-item__switch {
  transform: scale(0.85);
}

.sheet-controls {
  display: flex;
  gap: 16rpx;
}

.sheet-controls--dual .btn {
  flex: 1;
}

.btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.is-active {
  opacity: 0.85;
  transform: scale(0.98);
}

.locate-button {
  position: absolute;
  right: 2rpx;
  bottom: calc(50rpx + constant(safe-area-inset-bottom));
  bottom: calc(50rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: transparent;
  border: none;
  box-shadow: none;
  z-index: 99;
}

.locate-button__icon {
  font-size: 56rpx;
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.8), 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  touch-action: manipulation;
}

.locate-button::after {
  content: '';
  position: absolute;
  top: -16rpx;
  bottom: -16rpx;
  left: -16rpx;
  right: -16rpx;
}

.locate-button.is-active {
  background: rgba(47, 107, 255, 0.08);
}

.locate-button--active {
  animation: locatePulse 0.6s ease-in-out infinite alternate;
}

@keyframes locatePulse {
  from {
    transform: scale(1);
  }
  to {
    transform: scale(0.95);
  }
}

.btn {
  flex: 1;
  border: none;
  border-radius: 999rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn::after {
  border: none;
}

.btn--primary {
  background: linear-gradient(135deg, #2563eb, #4c1d95);
  color: #ffffff;
  box-shadow: 0 20rpx 40rpx rgba(37, 99, 235, 0.45);
}

.btn--ghost {
  background: rgba(37, 99, 235, 0.1);
  color: var(--color-primary-strong);
  border: 1px solid rgba(37, 99, 235, 0.3);
}

.btn--danger {
  background: linear-gradient(135deg, #f43f5e, #fb923c);
  color: #ffffff;
  box-shadow: 0 20rpx 40rpx rgba(244, 63, 94, 0.4);
}

.btn--camera {
  flex: initial;
  width: 100%;
  background: rgba(15, 23, 42, 0.08);
  color: var(--color-text-primary);
  border: 1px dashed rgba(15, 23, 42, 0.2);
}

.purpose-picker-overlay,
.finish-sheet-overlay,
.location-permission-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  backdrop-filter: blur(12rpx);
  background: var(--overlay-scrim);
  z-index: 20;
}

.purpose-picker {
  width: 100%;
  max-width: 700rpx;
  background: var(--color-surface);
  border-radius: 32rpx;
  padding: 36rpx;
  box-shadow: 0 40rpx 90rpx rgba(15, 23, 42, 0.15);
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.purpose-picker__header {
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.purpose-picker__title {
  font-size: 34rpx;
  font-weight: 600;
}

.purpose-picker__subtitle {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.purpose-picker__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.purpose-picker__item {
  padding: 24rpx 12rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(37, 99, 235, 0.2);
  background: rgba(37, 99, 235, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: var(--color-text-secondary);
}

.purpose-picker__item--active {
  border-color: rgba(37, 99, 235, 0.9);
  background: linear-gradient(145deg, rgba(37, 99, 235, 0.2), rgba(14, 165, 233, 0.2));
  color: var(--color-primary-strong);
  box-shadow: 0 18rpx 40rpx rgba(37, 99, 235, 0.25);
}

.purpose-picker__item-icon text {
  font-size: 44rpx;
}

.purpose-picker__item-label {
  font-size: 26rpx;
  font-weight: 600;
}

.purpose-picker__note {
  font-size: 24rpx;
  text-align: center;
  color: var(--color-text-secondary);
}

.purpose-picker__actions {
  display: flex;
  gap: 20rpx;
}

.finish-sheet {
  width: 100%;
  max-width: 720rpx;
  background: var(--color-surface);
  border-radius: 36rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  box-shadow: 0 40rpx 100rpx rgba(15, 23, 42, 0.15);
}

.finish-sheet__header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  text-align: center;
}

.finish-sheet__title {
  font-size: 34rpx;
  font-weight: 600;
}

.finish-sheet__subtitle {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.finish-field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.finish-field__label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.finish-field__hint {
  font-size: 24rpx;
  color: #ea580c;
  background: rgba(234, 88, 12, 0.08);
  border-radius: 16rpx;
  padding: 8rpx 14rpx;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.finish-field__input,
.finish-field__textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  border: 1px solid var(--color-border);
  background: var(--color-surface-muted);
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.finish-field__textarea {
  min-height: 140rpx;
}

.finish-privacy {
  display: flex;
  gap: 24rpx;
}

.finish-privacy__item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
}

.finish-photo__actions {
  margin-top: 8rpx;
  display: flex;
  gap: 12rpx;
}

.finish-photo__actions .btn--camera,
.finish-photo__retry-all {
  flex: 1;
  width: auto;
  min-width: 0;
}

.finish-photo__batch-progress {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.finish-photo__grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.finish-photo__item {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 20rpx;
  overflow: hidden;
}

.finish-photo__item image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.finish-photo__remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  border-radius: 50%;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.finish-photo__state {
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(127, 29, 29, 0.82);
  color: #fff7ed;
  font-size: 22rpx;
}

.finish-photo__state-retry {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
}

.finish-sheet__actions {
  display: flex;
  gap: 20rpx;
}

.location-permission-dialog {
  width: 100%;
  max-width: 680rpx;
  border-radius: 32rpx;
  background: var(--record-dialog-bg, rgba(255, 255, 255, 0.95));
  padding: 36rpx;
  box-shadow: 0 32rpx 80rpx rgba(15, 23, 42, 0.15);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.location-permission-dialog__badge {
  align-self: center;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.1);
  color: var(--color-primary-strong);
}

.location-permission-dialog__title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.location-permission-dialog__desc,
.location-permission-dialog__tip {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.6;
}

.location-permission-dialog__actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.location-permission-dialog__primary {
  background: linear-gradient(135deg, #2563eb, #4c1d95);
  border-radius: 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  padding: 24rpx;
}

.location-permission-dialog__secondary {
  background: rgba(37, 99, 235, 0.08);
  border-radius: 24rpx;
  color: var(--color-primary-strong);
  font-size: 28rpx;
  padding: 24rpx;
  border: 1px solid rgba(37, 99, 235, 0.2);
}
.reward-modal-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  background: var(--overlay-scrim);
  backdrop-filter: blur(10rpx);
  z-index: 30;
}

.reward-modal {
  width: 100%;
  max-width: 640rpx;
  background: var(--color-surface);
  border-radius: 36rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 50rpx 120rpx rgba(15, 23, 42, 0.15);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  text-align: center;
}

.reward-modal__title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.reward-modal__stats {
  background: rgba(15, 23, 42, 0.04);
  border-radius: 24rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.reward-modal__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.reward-modal__label {
  font-weight: 500;
}

.reward-modal__value {
  font-weight: 700;
  color: var(--color-text-primary);
}

.reward-modal__points {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.reward-modal__points-label {
  color: var(--color-text-secondary);
}

.reward-modal__points-gain {
  font-size: 40rpx;
  font-weight: 700;
  color: #facc15;
}

.reward-modal__points-stars {
  font-size: 30rpx;
}

.reward-modal__total {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.reward-modal__total-value {
  font-weight: 700;
  color: var(--color-primary);
  margin-left: 4rpx;
}

.reward-modal__cta {
  margin-top: 8rpx;
}

/* ══════ Finish Wizard ══════ */

.wizard-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  background: var(--overlay-scrim, rgba(15, 23, 42, 0.55));
  backdrop-filter: blur(16rpx);
  z-index: 25;
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.wizard-progress {
  padding: 20rpx 40rpx 0;
  flex-shrink: 0;
}

.wizard-progress__bar {
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  overflow: hidden;
}

.wizard-progress__fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2563eb, #7c3aed);
  transition: width 0.4s ease;
}

.wizard-progress__steps {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.wizard-progress__dot {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  opacity: 0.4;
  transition: opacity 0.3s ease;
}

.wizard-progress__dot--active {
  opacity: 1;
}

.wizard-progress__dot-label {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 500;
}

.wizard-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin: 20rpx 24rpx;
  margin-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  margin-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-surface);
  border-radius: 36rpx;
  padding: 32rpx;
  box-shadow: 0 40rpx 100rpx rgba(15, 23, 42, 0.2);
  overflow: hidden;
}

.wizard-card--tall {
  min-height: 0;
}

.wizard-card--reward {
  justify-content: center;
}

.wizard-card__header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  text-align: center;
  flex-shrink: 0;
  margin-bottom: 20rpx;
}

.wizard-card__title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.wizard-card__subtitle {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.wizard-card__body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  overflow-y: auto;
}

.wizard-card__body--scroll {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.wizard-card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-shrink: 0;
}

/* ── Step 1: End Point Map ── */

.wizard-card__map-wrap {
  flex: 1;
  min-height: 360rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
}

.wizard-card__map {
  width: 100%;
  height: 100%;
}

.wizard-card__map-hint {
  position: absolute;
  bottom: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(15, 23, 42, 0.75);
  color: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  backdrop-filter: blur(8rpx);
  white-space: nowrap;
}

/* ── Step 2: Satisfaction ── */

.satisfaction {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 0;
}

.satisfaction__emoji {
  font-size: 80rpx;
  transition: transform 0.2s ease;
}

.satisfaction__label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  min-height: 40rpx;
}

.satisfaction__track-wrap {
  width: 100%;
  position: relative;
  padding: 0 16rpx;
}

.satisfaction__track {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.08);
  overflow: hidden;
}

.satisfaction__track-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.15s ease, background 0.3s ease;
}

.satisfaction__slider {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  transform: translateY(-50%);
  margin: 0;
}

.satisfaction__scale {
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 0 16rpx;
}

.satisfaction__scale-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.satisfaction__ticks {
  display: flex;
  gap: 12rpx;
}

.satisfaction__tick {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  background: rgba(15, 23, 42, 0.06);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.satisfaction__tick--active {
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #7c3aed);
  border-color: rgba(37, 99, 235, 0.5);
  transform: scale(1.15);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.35);
}

/* ── Step 3: Route Comparison Map ── */

.wizard-card__route-map-wrap {
  border-radius: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.wizard-card__route-map {
  width: 100%;
  height: 320rpx;
}

.wizard-card__route-legend {
  padding: 12rpx 16rpx;
  background: rgba(15, 23, 42, 0.04);
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.route-legend__item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.route-legend__line {
  width: 24rpx;
  height: 6rpx;
  border-radius: 999rpx;
}

.wizard-card__route-map-loading {
  padding: 40rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

/* ── Preference chips ── */

.preference-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preference-chip {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(37, 99, 235, 0.2);
  background: rgba(37, 99, 235, 0.04);
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--color-text-secondary);
  transition: all 0.2s ease;
}

.preference-chip--active {
  border-color: rgba(37, 99, 235, 0.9);
  background: linear-gradient(145deg, rgba(37, 99, 235, 0.18), rgba(124, 58, 237, 0.18));
  color: var(--color-primary-strong);
  box-shadow: 0 12rpx 32rpx rgba(37, 99, 235, 0.2);
}

.preference-chip__icon {
  font-size: 28rpx;
}

.preference-chip__label {
  font-size: 26rpx;
  font-weight: 600;
}

/* ── Wizard Summary ── */

.wizard-summary {
  background: rgba(15, 23, 42, 0.04);
  border-radius: 24rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.wizard-summary__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
}

.wizard-summary__label {
  color: var(--color-text-secondary);
}

.wizard-summary__value {
  font-weight: 700;
  color: var(--color-text-primary);
}

/* ── Reward Celebration (inside wizard) ── */

.reward-celebration {
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
}

.reward-celebration__title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.reward-celebration__stats {
  width: 100%;
  background: rgba(15, 23, 42, 0.04);
  border-radius: 24rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.reward-celebration__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.reward-celebration__label {
  font-weight: 500;
}

.reward-celebration__value {
  font-weight: 700;
  color: var(--color-text-primary);
}

.reward-celebration__points {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 28rpx;
}

.reward-celebration__points-label {
  color: var(--color-text-secondary);
}

.reward-celebration__points-gain {
  font-size: 48rpx;
  font-weight: 700;
  color: #facc15;
}

.reward-celebration__points-stars {
  font-size: 32rpx;
}

.reward-celebration__total {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.reward-celebration__total-value {
  font-weight: 700;
  color: var(--color-primary);
}

/* ── Smooth transitions for sheet elements ── */
.record-sheet,
.metric,
.meta-inline,
.meta-item,
.status-chip,
.btn--camera,
.btn--ghost,
.wizard-card,
.purpose-picker,
.location-permission-dialog {
  transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
}

/* ── Dark mode overrides ── */
.dark .map-tip {
  background: rgba(2, 8, 23, 0.7);
  border-color: rgba(255, 255, 255, 0.08);
}

.dark .record-sheet {
  --record-sheet-bg: rgba(30, 41, 59, 0.94);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.35);
}

.dark .purpose-picker {
  box-shadow: 0 40rpx 90rpx rgba(0, 0, 0, 0.4);
}

.dark .location-permission-dialog {
  --record-dialog-bg: rgba(30, 41, 59, 0.95);
  box-shadow: 0 32rpx 80rpx rgba(0, 0, 0, 0.4);
}

.dark .wizard-card {
  box-shadow: 0 40rpx 100rpx rgba(0, 0, 0, 0.4);
}

.dark .wizard-progress__bar {
  background: rgba(255, 255, 255, 0.1);
}

.dark .satisfaction__track {
  background: rgba(255, 255, 255, 0.08);
}

.dark .satisfaction__tick {
  background: rgba(255, 255, 255, 0.06);
}

.dark .preference-chip {
  background: rgba(37, 99, 235, 0.08);
  border-color: rgba(37, 99, 235, 0.25);
}

.dark .wizard-summary,
.dark .reward-celebration__stats {
  background: rgba(255, 255, 255, 0.06);
}

.dark .wizard-card__route-legend {
  background: rgba(255, 255, 255, 0.04);
}

.dark .metric {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.05);
}

.dark .meta-inline {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.05);
}

.dark .meta-item {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.05);
}

.dark .meta-inline__divider {
  background: rgba(148, 163, 184, 0.2);
}

.dark .record-sheet__grabber {
  background: rgba(148, 163, 184, 0.25);
}

.dark .status-chip {
  --chip-blue-text: #93c5fd;
  --chip-blue-bg: rgba(59, 130, 246, 0.2);
}

.dark .status-chip--warn {
  --chip-warn-text: #fbbf24;
  --chip-warn-bg: rgba(245, 158, 11, 0.2);
}

.dark .status-chip--sync {
  --chip-sync-text: #94a3b8;
  --chip-sync-bg: rgba(148, 163, 184, 0.15);
}

.dark .btn--camera {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.15);
}

.dark .btn--ghost {
  background: rgba(37, 99, 235, 0.15);
  border-color: rgba(37, 99, 235, 0.35);
}

.dark .meta-inline__badge {
  background: rgba(59, 130, 246, 0.18);
}
