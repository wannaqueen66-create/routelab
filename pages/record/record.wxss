.record-page {
  min-height: 100vh;
  background: #020817;
  color: #0f172a;
  display: flex;
  flex-direction: column;
  -webkit-overflow-scrolling: touch;
}

.map-region {
  position: relative;
  flex: 0 0 58vh;
  max-height: 70vh;
  overflow: hidden;
  z-index: 0;
}

.record-map {
  width: 100%;
  height: 100%;
}

.record-nav {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  pointer-events: none;
}

.record-nav rlab-nav {
  pointer-events: auto;
}

.map-tip {
  position: absolute;
  top: 64rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(2, 8, 23, 0.7);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #f8fafc;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  backdrop-filter: blur(12rpx);
}

.sheet-container {
  flex: 1;
  width: 100%;
  margin-top: -48rpx;
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  background: #020817;
}

.record-sheet {
  margin: 0 24rpx;
  padding: 28rpx 32rpx;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(20rpx);
  border-radius: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(2, 8, 23, 0.28);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-sheet__grabber {
  width: 100rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.4);
  margin: 0 auto;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.metric {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.06);
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.metric__icon {
  font-size: 32rpx;
}

.metric__texts {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.metric__label {
  font-size: 24rpx;
  color: #64748b;
}

.metric__value {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.2;
  -webkit-font-smoothing: antialiased;
}

.sheet-meta {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.status-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.status-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #1e3a8a;
  background: rgba(30, 64, 175, 0.12);
}

.status-chip--warn {
  color: #b45309;
  background: rgba(245, 158, 11, 0.2);
}

.status-chip--sync {
  color: #334155;
  background: rgba(148, 163, 184, 0.22);
}

.meta-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.05);
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.meta-inline__cell {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-inline__hint {
  font-size: 24rpx;
  color: #94a3b8;
}

.meta-inline__cell--static .meta-inline__value {
  color: #0f172a;
}

.meta-inline__cell--action {
  justify-content: flex-start;
  gap: 12rpx;
}

.meta-inline__cell--disabled {
  opacity: 0.65;
}

.meta-inline__label-text {
  font-size: 26rpx;
  color: #64748b;
}

.meta-inline__value {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.meta-inline__texts {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.meta-inline__value-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-inline__badge {
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #2563eb;
  background: rgba(37, 99, 235, 0.12);
}

.meta-inline__divider {
  width: 1px;
  height: 36rpx;
  margin: 0 16rpx;
  background: rgba(148, 163, 184, 0.4);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.05);
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.meta-item__icon {
  font-size: 32rpx;
}

.meta-item__label {
  font-size: 26rpx;
  color: #0f172a;
}

.meta-item--toggle {
  justify-content: space-between;
}

.meta-item__label--inline {
  flex: 1;
}

.meta-item__switch {
  transform: scale(0.85);
}

.sheet-controls {
  display: flex;
  gap: 16rpx;
}

.sheet-controls--dual .btn {
  flex: 1;
}

.btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.is-active {
  opacity: 0.85;
  transform: scale(0.98);
}

.locate-button {
  position: absolute;
  right: 2rpx;
  bottom: calc(50rpx + constant(safe-area-inset-bottom));
  bottom: calc(50rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: transparent;
  border: none;
  box-shadow: none;
  z-index: 99;
}

.locate-button__icon {
  font-size: 56rpx;
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.8), 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  touch-action: manipulation;
}

.locate-button::after {
  content: '';
  position: absolute;
  top: -16rpx;
  bottom: -16rpx;
  left: -16rpx;
  right: -16rpx;
}

.locate-button.is-active {
  background: rgba(47, 107, 255, 0.08);
}

.locate-button--active {
  animation: locatePulse 0.6s ease-in-out infinite alternate;
}

@keyframes locatePulse {
  from {
    transform: scale(1);
  }
  to {
    transform: scale(0.95);
  }
}

.btn {
  flex: 1;
  border: none;
  border-radius: 999rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn::after {
  border: none;
}

.btn--primary {
  background: linear-gradient(135deg, #2563eb, #4c1d95);
  color: #ffffff;
  box-shadow: 0 20rpx 40rpx rgba(37, 99, 235, 0.45);
}

.btn--ghost {
  background: rgba(37, 99, 235, 0.1);
  color: #1d4ed8;
  border: 1px solid rgba(37, 99, 235, 0.3);
}

.btn--danger {
  background: linear-gradient(135deg, #f43f5e, #fb923c);
  color: #ffffff;
  box-shadow: 0 20rpx 40rpx rgba(244, 63, 94, 0.4);
}

.btn--camera {
  flex: initial;
  width: 100%;
  background: rgba(15, 23, 42, 0.08);
  color: #0f172a;
  border: 1px dashed rgba(15, 23, 42, 0.2);
}

.purpose-picker-overlay,
.finish-sheet-overlay,
.location-permission-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  backdrop-filter: blur(12rpx);
  background: rgba(2, 8, 23, 0.55);
  z-index: 20;
}

.purpose-picker {
  width: 100%;
  max-width: 700rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 36rpx;
  box-shadow: 0 40rpx 90rpx rgba(2, 8, 23, 0.35);
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.purpose-picker__header {
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.purpose-picker__title {
  font-size: 34rpx;
  font-weight: 600;
}

.purpose-picker__subtitle {
  font-size: 24rpx;
  color: #64748b;
}

.purpose-picker__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.purpose-picker__item {
  padding: 24rpx 12rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(37, 99, 235, 0.2);
  background: rgba(37, 99, 235, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: #475569;
}

.purpose-picker__item--active {
  border-color: rgba(37, 99, 235, 0.9);
  background: linear-gradient(145deg, rgba(37, 99, 235, 0.2), rgba(14, 165, 233, 0.2));
  color: #1d4ed8;
  box-shadow: 0 18rpx 40rpx rgba(37, 99, 235, 0.25);
}

.purpose-picker__item-icon text {
  font-size: 44rpx;
}

.purpose-picker__item-label {
  font-size: 26rpx;
  font-weight: 600;
}

.purpose-picker__note {
  font-size: 24rpx;
  text-align: center;
  color: #64748b;
}

.purpose-picker__actions {
  display: flex;
  gap: 20rpx;
}

.finish-sheet {
  width: 100%;
  max-width: 720rpx;
  background: #ffffff;
  border-radius: 36rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  box-shadow: 0 40rpx 100rpx rgba(2, 8, 23, 0.38);
}

.finish-sheet__header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  text-align: center;
}

.finish-sheet__title {
  font-size: 34rpx;
  font-weight: 600;
}

.finish-sheet__subtitle {
  font-size: 24rpx;
  color: #64748b;
}

.finish-field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.finish-field__label {
  font-size: 24rpx;
  color: #475569;
}

.finish-field__hint {
  font-size: 24rpx;
  color: #ea580c;
  background: rgba(234, 88, 12, 0.08);
  border-radius: 16rpx;
  padding: 8rpx 14rpx;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.finish-field__input,
.finish-field__textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  border: 1px solid rgba(148, 163, 184, 0.4);
  background: rgba(248, 250, 252, 0.9);
  font-size: 28rpx;
}

.finish-field__textarea {
  min-height: 140rpx;
}

.finish-privacy {
  display: flex;
  gap: 24rpx;
}

.finish-privacy__item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
}

.finish-photo__actions {
  margin-top: 8rpx;
  display: flex;
  gap: 12rpx;
}

.finish-photo__actions .btn--camera,
.finish-photo__retry-all {
  flex: 1;
  width: auto;
  min-width: 0;
}

.finish-photo__batch-progress {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.finish-photo__grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.finish-photo__item {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 20rpx;
  overflow: hidden;
}

.finish-photo__item image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.finish-photo__remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  border-radius: 50%;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.finish-photo__state {
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(127, 29, 29, 0.82);
  color: #fff7ed;
  font-size: 22rpx;
}

.finish-photo__state-retry {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
}

.finish-sheet__actions {
  display: flex;
  gap: 20rpx;
}

.location-permission-dialog {
  width: 100%;
  max-width: 680rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 36rpx;
  box-shadow: 0 32rpx 80rpx rgba(2, 8, 23, 0.35);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.location-permission-dialog__badge {
  align-self: center;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.1);
  color: #1d4ed8;
}

.location-permission-dialog__title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.location-permission-dialog__desc,
.location-permission-dialog__tip {
  font-size: 24rpx;
  color: #475569;
  text-align: center;
  line-height: 1.6;
}

.location-permission-dialog__actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.location-permission-dialog__primary {
  background: linear-gradient(135deg, #2563eb, #4c1d95);
  border-radius: 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  padding: 24rpx;
}

.location-permission-dialog__secondary {
  background: rgba(37, 99, 235, 0.08);
  border-radius: 24rpx;
  color: #1d4ed8;
  font-size: 28rpx;
  padding: 24rpx;
  border: 1px solid rgba(37, 99, 235, 0.2);
}
.reward-modal-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  background: rgba(2, 6, 23, 0.65);
  backdrop-filter: blur(10rpx);
  z-index: 30;
}

.reward-modal {
  width: 100%;
  max-width: 640rpx;
  background: #ffffff;
  border-radius: 36rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 50rpx 120rpx rgba(15, 23, 42, 0.35);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  text-align: center;
}

.reward-modal__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.reward-modal__stats {
  background: rgba(15, 23, 42, 0.04);
  border-radius: 24rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.reward-modal__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #475569;
}

.reward-modal__label {
  font-weight: 500;
}

.reward-modal__value {
  font-weight: 700;
  color: #0f172a;
}

.reward-modal__points {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #0f172a;
}

.reward-modal__points-label {
  color: #475569;
}

.reward-modal__points-gain {
  font-size: 40rpx;
  font-weight: 700;
  color: #facc15;
}

.reward-modal__points-stars {
  font-size: 30rpx;
}

.reward-modal__total {
  font-size: 26rpx;
  color: #475569;
}

.reward-modal__total-value {
  font-weight: 700;
  color: #2563eb;
  margin-left: 4rpx;
}

.reward-modal__cta {
  margin-top: 8rpx;
}
