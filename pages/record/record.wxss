.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #eef2ff;
}

.page__scroll {
  flex: 1;
  padding: 32rpx 32rpx 72rpx;
  box-sizing: border-box;
}

.map-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  box-shadow: 0 20rpx 36rpx rgba(79, 70, 229, 0.18);
  margin-bottom: 32rpx;
}

.map-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(16, 23, 53, 0.6);
  color: #f8fafc;
  font-size: 28rpx;
  letter-spacing: 1rpx;
}

.section {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 28rpx;
}

.section--light {
  background: linear-gradient(180deg, #f5f3ff 0%, #ffffff 70%);
  box-shadow: 0 12rpx 28rpx rgba(99, 102, 241, 0.12);
}

.section--surface {
  background: #f9fafb;
  border: 2rpx solid rgba(148, 163, 184, 0.2);
}

.section__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.activity-selector {
  display: flex;
  gap: 16rpx;
}

.activity-selector__item {
  flex: 1;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  color: #4f46e5;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.activity-selector__item--active {
  background: linear-gradient(135deg, #6366f1, #4338ca);
  color: #ffffff;
  box-shadow: 0 16rpx 28rpx rgba(79, 70, 229, 0.25);
}

.activity-selector__label {
  letter-spacing: 1rpx;
}

.activity-selector__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6366f1;
}

.location-row {
  margin-top: 20rpx;
}

.location-row__label {
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 12rpx;
  display: block;
}

.picker {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.picker--surface {
  background: rgba(99, 102, 241, 0.08);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid rgba(99, 102, 241, 0.15);
}

.picker--pending {
  border-style: dashed;
  border-color: rgba(99, 102, 241, 0.45);
  background: rgba(99, 102, 241, 0.12);
}

.picker--input {
  background: rgba(148, 163, 184, 0.12);
  border-radius: 18rpx;
  padding: 18rpx 24rpx;
}

.picker--disabled {
  opacity: 0.6;
}

.picker__value-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.picker__value {
  font-size: 28rpx;
  color: #1e293b;
}

.picker__status {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(79, 70, 229, 0.12);
  color: #4f46e5;
  font-weight: 600;
}

.picker__hint {
  font-size: 22rpx;
  color: #64748b;
}

.stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: linear-gradient(150deg, #312e81, #4338ca);
  color: #f8fafc;
  border-radius: 24rpx;
  padding: 24rpx 26rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  box-shadow: 0 16rpx 32rpx rgba(49, 46, 129, 0.25);
}

.stat-card--wide {
  grid-column: span 2;
}

.stat-card__label {
  font-size: 24rpx;
  opacity: 0.75;
}

.stat-card__value {
  font-size: 36rpx;
  font-weight: 600;
}

.controls {
  margin: 32rpx 0 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: stretch;
}

.controls__group {
  display: flex;
  gap: 16rpx;
}

.controls__hint {
  font-size: 22rpx;
  color: #64748b;
}

.btn {
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border: none;
}

.btn--primary {
  background: linear-gradient(120deg, #f97316, #fb7185);
  color: #ffffff;
  box-shadow: 0 16rpx 32rpx rgba(249, 115, 22, 0.25);
}

.btn--secondary {
  flex: 1;
  background: linear-gradient(120deg, #38bdf8, #6366f1);
  color: #ffffff;
}

.btn--ghost {
  flex: 1;
  background: rgba(99, 102, 241, 0.12);
  color: #4338ca;
  border: 2rpx solid rgba(99, 102, 241, 0.25);
}

.btn--danger {
  flex: 1;
  background: linear-gradient(120deg, #f43f5e, #ef4444);
  color: #ffffff;
}

.photo-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.photo-grid__item {
  position: relative;
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 28rpx rgba(59, 130, 246, 0.2);
}

.photo-grid__image {
  width: 100%;
  height: 100%;
}

.photo-grid__remove {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.65);
  color: #ffffff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-grid__note {
  background: rgba(248, 250, 252, 0.9);
  border-radius: 18rpx;
  padding: 16rpx 20rpx;
  border: 2rpx solid rgba(148, 163, 184, 0.4);
  font-size: 26rpx;
  color: #1e293b;
}

.photo-section__empty {
  font-size: 24rpx;
  color: #64748b;
}

.form-row {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.form-label {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.input,
.textarea {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid rgba(148, 163, 184, 0.35);
  font-size: 26rpx;
  color: #1e293b;
}

.textarea {
  min-height: 120rpx;
}

.shortcut {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.link-button {
  background: rgba(99, 102, 241, 0.12);
  border: 2rpx solid rgba(99, 102, 241, 0.25);
  color: #4338ca;
  border-radius: 999rpx;
  padding: 0 32rpx;
  height: 64rpx;
  line-height: 64rpx;
}
