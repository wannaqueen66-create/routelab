.survey-gate-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef6ff 0%, #f8fbff 100%);
}

.survey-gate-scroll {
  height: calc(100vh - 88rpx);
  box-sizing: border-box;
  padding: 32rpx 24rpx 48rpx;
}

.survey-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 32rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.08);
}

.survey-card__eyebrow {
  display: block;
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.survey-card__title {
  display: block;
  font-size: 42rpx;
  line-height: 1.3;
  color: #0f172a;
  font-weight: 700;
}

.survey-card__desc {
  display: block;
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #475569;
}

.survey-status {
  margin-top: 28rpx;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
}

.survey-status--pending {
  background: rgba(37, 99, 235, 0.08);
  color: #1d4ed8;
}

.survey-status--active {
  background: rgba(14, 165, 233, 0.12);
  color: #0369a1;
}

.survey-status--ok {
  background: rgba(34, 197, 94, 0.12);
  color: #15803d;
}

.survey-status--error {
  background: rgba(239, 68, 68, 0.12);
  color: #b91c1c;
}

.survey-status__label {
  font-size: 28rpx;
  font-weight: 600;
}

.survey-meta {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #64748b;
}

.survey-alert {
  margin-top: 26rpx;
  border-radius: 24rpx;
  padding: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
}

.survey-alert--error {
  background: rgba(254, 226, 226, 0.92);
  color: #b91c1c;
}

.survey-alert--ok {
  background: rgba(220, 252, 231, 0.92);
  color: #15803d;
}

.survey-alert__hint {
  display: block;
  margin-top: 8rpx;
}

.survey-alert__action {
  margin-top: 18rpx;
}

.survey-steps {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.survey-step {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(248, 250, 252, 0.96);
}

.survey-step__index {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
  flex-shrink: 0;
}

.survey-step__text {
  flex: 1;
  font-size: 26rpx;
  color: #334155;
  line-height: 1.6;
}

.survey-actions {
  margin-top: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.survey-actions__confirm[disabled] {
  opacity: 0.5;
}

.dark.survey-gate-page {
  background: linear-gradient(180deg, #0f172a 0%, #111827 100%);
}

.dark .survey-card {
  background: rgba(15, 23, 42, 0.92);
  box-shadow: 0 18rpx 48rpx rgba(2, 6, 23, 0.28);
}

.dark .survey-card__eyebrow {
  color: #60a5fa;
}

.dark .survey-card__title {
  color: #f8fafc;
}

.dark .survey-card__desc {
  color: #cbd5e1;
}

.dark .survey-meta {
  color: #94a3b8;
}

.dark .survey-step {
  background: rgba(30, 41, 59, 0.92);
}

.dark .survey-step__text {
  color: #e2e8f0;
}
