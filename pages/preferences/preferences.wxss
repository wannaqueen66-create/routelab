.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(
    --gradient-page,
    linear-gradient(180deg, var(--color-page-bg) 0%, var(--color-page-bg-strong) 100%)
  );
  color: var(--color-text-primary);
  transition: background 0.3s ease, color 0.3s ease;
}

.page__scroll {
  flex: 1;
  padding: var(--spacing-page, 32rpx);
  padding-bottom: calc(var(--spacing-page, 32rpx) + env(safe-area-inset-bottom) + 20rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-section-gap, 24rpx);
}

.section {
  background: var(--color-surface);
  border-radius: var(--radius-card, 32rpx);
  padding: var(--spacing-card, 28rpx);
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  transition: background 0.3s ease, box-shadow 0.3s ease;
}

.section__title {
  font-size: 32rpx;
  font-weight: 600;
}

.section--profile-cta {
  background: var(--gradient-hero);
  border: 1px solid var(--color-border);
}

/* ── Theme selector ── */
.theme-options {
  display: flex;
  gap: 16rpx;
}

.theme-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 12rpx;
  border-radius: 20rpx;
  background: var(--color-surface-muted);
  border: 2rpx solid var(--color-border);
  transition: border-color 0.25s ease, background 0.25s ease, transform 0.2s ease;
}

.theme-option:active {
  transform: scale(0.97);
}

.theme-option--active {
  border-color: var(--color-primary);
  background: var(--color-primary-soft);
}

.theme-option__icon {
  font-size: 36rpx;
}

.theme-option__label {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.theme-option--active .theme-option__label {
  color: var(--color-primary);
  font-weight: 600;
}

/* ── Picker ── */
.picker {
  background: var(--color-surface-muted);
  border-radius: 20rpx;
  padding: 22rpx;
  border: 1px solid var(--color-border);
}

.picker__value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.picker__desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.section__desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* ── Field ── */
.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field--inline {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.field__label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.field__input {
  background: var(--color-surface-muted);
  border-radius: 20rpx;
  padding: 20rpx;
  border: 1px solid var(--color-border);
  color: var(--color-text-primary);
  font-size: 28rpx;
  transition: border-color 0.25s ease, box-shadow 0.25s ease;
}

.field__input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx var(--color-primary-soft);
}

.field__input::placeholder {
  color: var(--color-text-tertiary);
}

/* ── Actions ── */
.actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 12rpx;
}

.btn {
  border: none;
  border-radius: var(--radius-pill, 999rpx);
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.btn:active {
  transform: translateY(2rpx) scale(0.98);
}

.btn--primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-strong));
  color: #ffffff;
  box-shadow: 0 20rpx 40rpx rgba(47, 107, 255, 0.3);
}

.btn--accent {
  background: var(--color-surface);
  color: var(--color-primary);
  border: 1rpx solid rgba(47, 107, 255, 0.3);
  box-shadow: 0 16rpx 32rpx rgba(47, 107, 255, 0.15);
}

.btn--ghost {
  background: rgba(47, 107, 255, 0.1);
  color: var(--color-primary);
  border: 1px solid rgba(47, 107, 255, 0.3);
}

.btn::after {
  display: none;
}

.message {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 12rpx;
}

/* ── Dark mode overrides ── */
.dark .btn--primary {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  box-shadow: 0 20rpx 40rpx rgba(59, 130, 246, 0.3);
}

.dark .btn--accent {
  background: var(--color-surface);
  border-color: rgba(96, 165, 250, 0.2);
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.2);
}
