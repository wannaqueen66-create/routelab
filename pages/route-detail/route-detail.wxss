.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(
    --gradient-page,
    linear-gradient(180deg, var(--color-page-bg) 0%, var(--color-page-bg-strong) 100%)
  );
  color: var(--color-text-primary);
}

.page__scroll {
  flex: 1;
  padding: 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.map {
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card-hover);
}

.section {
  background: var(--color-surface);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}

.section__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section__title {
  font-size: 34rpx;
  font-weight: 600;
}

.purpose-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
}

.purpose-card--empty {
  border-style: dashed;
  border-color: var(--color-border);
}

.purpose-card__icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: rgba(47, 107, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--color-primary);
}

.purpose-card__content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.purpose-card__label {
  font-size: 32rpx;
  font-weight: 600;
}

.purpose-card__desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.section__sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.privacy-picker {
  padding: 16rpx 24rpx;
  border-radius: 18rpx;
  background: var(--color-surface-muted);
  color: var(--color-text-primary);
  font-size: 24rpx;
}

.privacy-picker--disabled {
  opacity: 0.6;
}

.category {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category__badge {
  align-self: flex-start;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  background: rgba(47, 107, 255, 0.08);
  border: 1px solid rgba(47, 107, 255, 0.2);
}

.category__summary {
  font-size: 26rpx;
  font-weight: 600;
}

.category__desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.category-legend__grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 12rpx;
}

.category-legend__item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.category-legend__dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-top: 8rpx;
}

.category-legend__label {
  font-size: 26rpx;
  font-weight: 500;
}

.category-legend__summary,
.category-legend__desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.stat-card {
  background: var(--color-surface-muted);
  border-radius: 22rpx;
  padding: 22rpx;
  border: 1px solid var(--color-border);
}

.stat-card__label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.stat-card__value {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.photo-gallery {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.photo-gallery__item {
  position: relative;
  border-radius: 18rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.photo-gallery__image {
  width: 100%;
  height: 220rpx;
}

.photo-gallery__note {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx 16rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.55) 100%);
  color: #fef3f7;
  font-size: 22rpx;
}

.note {
  background: var(--color-surface-muted);
  border-radius: 20rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.actions .btn {
  flex: 1;
}

.btn--danger {
  background: linear-gradient(135deg, #f87171, #fb7185);
  box-shadow: 0 18rpx 36rpx rgba(248, 113, 113, 0.35);
}

.btn--ghost {
  background: transparent;
  border: 1px solid rgba(47, 107, 255, 0.25);
  color: var(--color-primary);
}

.empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.section--comments {
  margin-top: 24rpx;
  padding: 24rpx;
  background: var(--color-surface-muted);
  border-radius: 16rpx;
}

.comments__loading,
.comments__empty,
.comments__error {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  padding: 20rpx 0;
}

.comments__error .pill-button {
  margin-top: 12rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comment-item {
  background: var(--color-surface);
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.08);
}

.comment-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.comment-item__author {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.comment-item__time {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.comment-item__content {
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.comment-item__actions {
  margin-top: 12rpx;
  display: flex;
  gap: 24rpx;
}

.comment-action {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.comment-action__icon {
  font-size: 24rpx;
}

.comment-action--active {
  color: #ef4444;
}

.comment-action--danger {
  color: #dc2626;
}

.comment-replies {
  margin-top: 16rpx;
  padding-left: 20rpx;
  border-left: 4rpx solid var(--color-border);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.comment-reply__author {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.comment-reply__time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.comment-reply__content {
  font-size: 24rpx;
  color: var(--color-text-primary);
}

/* ── Smooth transitions ── */
.page,
.section,
.section--comments,
.comment-item,
.purpose-card,
.stat-card,
.note {
  transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
}

/* ── Dark mode overrides ── */
.dark .comment-item {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.dark .comment-action--active {
  color: #f87171;
}

.dark .comment-action--danger {
  color: #f87171;
}

.dark .photo-gallery__note {
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.7) 100%);
}

.dark .btn--danger {
  background: linear-gradient(135deg, #ef4444, #f97316);
  box-shadow: 0 18rpx 36rpx rgba(239, 68, 68, 0.25);
}

/* Weather card */
.weather-section {
  margin-top: 24rpx;
}
.weather-card {
  background: linear-gradient(135deg, #e0f2fe, #f0f9ff);
  border-radius: 20rpx;
  padding: 28rpx;
}
.weather-card__main {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.weather-card__temp {
  font-size: 56rpx;
  font-weight: 700;
  color: #0369a1;
}
.weather-card__text {
  font-size: 28rpx;
  color: #0c4a6e;
}
.weather-card__details {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.weather-card__item {
  flex: 1 1 40%;
  display: flex;
  justify-content: space-between;
  background: rgba(255,255,255,0.6);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
}
.weather-card__label {
  font-size: 24rpx;
  color: #64748b;
}
.weather-card__value {
  font-size: 24rpx;
  font-weight: 600;
  color: #1e293b;
}
.weather-card__suggestion {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(255,255,255,0.5);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.5;
}

/* Dark mode weather */
.dark .weather-card {
  background: linear-gradient(135deg, #1e3a5f, #0f2942);
}
.dark .weather-card__temp {
  color: #7dd3fc;
}
.dark .weather-card__text {
  color: #bae6fd;
}
.dark .weather-card__item {
  background: rgba(255,255,255,0.08);
}
.dark .weather-card__label {
  color: #94a3b8;
}
.dark .weather-card__value {
  color: #e2e8f0;
}
.dark .weather-card__suggestion {
  background: rgba(255,255,255,0.06);
  color: #94a3b8;
}
