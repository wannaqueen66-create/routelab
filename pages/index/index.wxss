.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f6f7fb 0%, #fdfefe 100%);
  color: #0f172a;
}

.page__scroll {
  flex: 1;
  padding: 24rpx 32rpx 0;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.banner {
  margin: 24rpx 32rpx 0;
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  text-align: center;
  background: rgba(250, 204, 21, 0.15);
  color: #b45309;
  border: 1px solid rgba(250, 204, 21, 0.3);
}

.tab-bar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding: 12rpx 20rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.12);
  z-index: 10;
}

.tab-bar__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx;
  border-radius: 28rpx;
  color: #94a3b8;
  transition: background 0.2s ease, color 0.2s ease;
}

.tab-bar__item--active {
  background: rgba(59, 130, 246, 0.12);
  color: #2563eb;
}

.tab-bar__icon {
  font-size: 40rpx;
}

.tab-bar__label {
  font-size: 26rpx;
  font-weight: 600;
}

.tab-bar__desc {
  font-size: 22rpx;
  color: inherit;
}

.tab-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 12rpx;
}

.home-fold {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.08);
}

.card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card__title {
  font-size: 32rpx;
  font-weight: 600;
}

.card--hero {
  background: linear-gradient(135deg, #edf4ff, #f5fbff);
  border: 1px solid rgba(59, 130, 246, 0.12);
}

.home-sync-banner {
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  margin-bottom: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.home-sync-banner--warn {
  background: rgba(245, 158, 11, 0.18);
  color: #92400e;
}

.home-sync-banner--danger {
  background: rgba(239, 68, 68, 0.18);
  color: #991b1b;
}

.home-sync-banner--ok {
  background: rgba(34, 197, 94, 0.15);
  color: #166534;
}

.home-sync-banner__title {
  font-size: 26rpx;
  font-weight: 600;
}

.home-sync-banner__desc {
  font-size: 22rpx;
  line-height: 1.45;
}

.home-sync-banner__retry {
  margin-top: 8rpx;
  align-self: flex-start;
  padding: 0 20rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.75);
  color: currentColor;
  border: 1px solid rgba(255, 255, 255, 0.55);
}

.home-sync-banner__retry::after {
  display: none;
}

.hero__eyebrow {
  font-size: 24rpx;
  color: #64748b;
}

.hero__title {
  font-size: 40rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.hero__desc {
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #475569;
}

.hero__top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.hero__titles {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.hero__actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.btn {
  border: none;
  border-radius: 999rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
}

.btn::after {
  border: none;
}

.btn--primary {
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  color: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(37, 99, 235, 0.4);
}

.btn--ghost {
  background: rgba(37, 99, 235, 0.1);
  color: #1d4ed8;
}

.hero__stats {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.hero__stat {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.5);
}

.hero__stat-value {
  font-size: 32rpx;
  font-weight: 700;
}

.hero__stat-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #475569;
}

.card--weather {
  padding-bottom: 28rpx;
}

.weather__headline {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.weather__temp {
  font-size: 64rpx;
  font-weight: 700;
}

.weather__status {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  color: #475569;
}

.weather__location {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #2563eb;
}

.weather__advice {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(248, 250, 252, 0.9);
}

.weather__advice-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.weather__metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.weather__metric {
  text-align: center;
  padding: 16rpx;
  border-radius: 20rpx;
  background: rgba(15, 23, 42, 0.03);
}

.weather__metric-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
}

.weather__metric-value {
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.weather__empty {
  padding: 32rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
}

.card--history {
  padding-bottom: 12rpx;
}

.history__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  gap: 12rpx;
}

.history__sync-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.history__filters {
  margin: 0 -20rpx 20rpx;
}

.history__filters-inner {
  display: flex;
  padding: 0 20rpx;
  gap: 12rpx;
}

.chip {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.15);
  color: #475569;
  font-size: 24rpx;
}

.chip--active {
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  color: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(37, 99, 235, 0.35);
}

.history__empty {
  padding: 40rpx 20rpx;
  text-align: center;
  border-radius: 28rpx;
  background: rgba(248, 250, 252, 0.9);
  border: 1px dashed rgba(148, 163, 184, 0.6);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history__empty-title {
  font-size: 32rpx;
  font-weight: 600;
}

.history__empty-desc {
  font-size: 26rpx;
  color: #64748b;
}

.history-route {
  margin-top: 16rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  border: 1px solid rgba(226, 232, 240, 0.9);
  background: rgba(248, 250, 252, 0.85);
}

.history-route__header {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.history-route__title {
  font-size: 30rpx;
  font-weight: 600;
}

.history-route__title-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.history-route__status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(249, 115, 22, 0.15);
  color: #f97316;
}

.history-route__status-icon {
  font-size: 24rpx;
}

.history-route__privacy {
  font-size: 24rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.1);
  color: #1d4ed8;
}

.history-route__meta,
.history-route__path,
.history-route__footer {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #475569;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.history-route__arrow {
  opacity: 0.5;
}

.history-route__extra {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.history-route__sync-error {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #991b1b;
  background: rgba(220, 38, 38, 0.08);
  border-radius: 12rpx;
  padding: 8rpx 10rpx;
}

.history-route__date {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.tab-content--profile {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 32rpx;
}

.profile-center {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.profile-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 16rpx 30rpx rgba(15, 23, 42, 0.08);
}

.profile-card__header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.profile-card__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-card__avatar image {
  width: 100%;
  height: 100%;
}

.profile-card__avatar-placeholder {
  font-size: 36rpx;
  font-weight: 700;
  color: #475569;
}

.profile-card__info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.profile-card__identity {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.profile-card__name {
  font-size: 32rpx;
  font-weight: 600;
}

.profile-card__status {
  font-size: 24rpx;
  color: #2563eb;
}

.profile-card__id {
  font-size: 22rpx;
  color: #94a3b8;
}

.profile-card__points {
  min-width: 170rpx;
  padding: 12rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(37, 99, 235, 0.08);
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  color: #1d4ed8;
  flex-shrink: 0;
}

.profile-card__points-label {
  font-size: 24rpx;
}

.profile-card__points-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.profile-card__points-sub {
  font-size: 24rpx;
  color: #64748b;
}

.profile-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 25rpx rgba(15, 23, 42, 0.06);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.profile-section--info {
  gap: 18rpx;
}

.profile-section--sync {
  gap: 18rpx;
}

.profile-section__cta {
  margin-top: 8rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1px solid rgba(148, 163, 184, 0.25);
}

.info-row:last-child {
  border-bottom: none;
}

.info-row__label {
  font-size: 26rpx;
  color: #94a3b8;
}

.info-row__value {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
}

.profile-section--settings {
  gap: 12rpx;
}

.sync-summary {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.sync-summary__item {
  flex: 1;
  border-radius: 20rpx;
  padding: 18rpx;
  background: rgba(226, 232, 240, 0.5);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.sync-summary__value {
  font-size: 38rpx;
  font-weight: 600;
  color: #0f172a;
}

.sync-summary__label {
  font-size: 24rpx;
  color: #475569;
}

.sync-meta {
  font-size: 24rpx;
  color: #64748b;
}

.settings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.settings-row__texts {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.settings-row__title {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
}

.settings-row__desc {
  font-size: 24rpx;
  color: #94a3b8;
}

.settings-divider {
  height: 1px;
  background: rgba(148, 163, 184, 0.25);
}

.settings-row__link-text {
  font-size: 26rpx;
  color: #2563eb;
}

.pill-button {
  border: none;
  border-radius: 999rpx;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  background: rgba(37, 99, 235, 0.12);
  color: #1d4ed8;
}

.pill-button--warn {
  background: rgba(245, 158, 11, 0.14);
  color: #b45309;
}

.announcement-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, 0.35);
  backdrop-filter: blur(4rpx);
  z-index: 40;
}

.announcement-dialog {
  width: 640rpx;
  max-height: 70vh;
  padding: 40rpx;
  border-radius: 28rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.announcement-dialog__header {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.announcement-dialog__title {
  font-size: 32rpx;
  font-weight: 600;
}

.announcement-dialog__time {
  font-size: 24rpx;
  color: #9ca3af;
}

.announcement-dialog__body {
  margin-top: 8rpx;
  max-height: 360rpx;
}

.announcement-dialog__content {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
  white-space: pre-wrap;
}

.announcement-dialog__actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.announcement-dialog__btn {
  border: none;
  border-radius: 999rpx;
  padding: 18rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.announcement-dialog__btn--primary {
  background: linear-gradient(135deg, #1d4ed8, #2563eb);
  color: #ffffff;
}

.permission-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, 0.35);
  backdrop-filter: blur(4rpx);
  z-index: 30;
}

.permission-dialog {
  width: 640rpx;
  padding: 40rpx;
  border-radius: 28rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.permission-dialog__title {
  font-size: 32rpx;
  font-weight: 600;
}

.permission-dialog__desc {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.5;
}

.permission-dialog__actions {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.permission-dialog__btn {
  border: none;
  border-radius: 999rpx;
  padding: 18rpx;
  font-size: 28rpx;
  text-align: center;
  background: rgba(148, 163, 184, 0.15);
  color: #1f2937;
}

.permission-dialog__btn--primary {
  background: linear-gradient(135deg, #1d4ed8, #2563eb);
  color: #ffffff;
}
