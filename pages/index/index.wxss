page {
  background: #f8fafc;
  min-height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.page__scroll {
  flex: 1;
  padding: 24rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.banner {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.banner--offline {
  background: #fde68a;
  color: #92400e;
}

.section {
  margin-bottom: 48rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.05);
}

.hero {
  background: linear-gradient(135deg, #0f172a, #1d4ed8 45%, #fb7185 110%);
  color: #f8fafc;
  position: relative;
  overflow: hidden;
}

.hero__subtitle {
  font-size: 26rpx;
  letter-spacing: 1rpx;
  text-transform: uppercase;
  color: rgba(248, 250, 252, 0.75);
}

.hero__title {
  font-size: 48rpx;
  font-weight: 700;
  margin-top: 20rpx;
  line-height: 1.35;
}

.hero__desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: rgba(241, 245, 249, 0.85);
}

.hero__cta {
  display: flex;
  margin-top: 32rpx;
  gap: 16rpx;
}

.cta__primary {
  flex: 1;
  background: linear-gradient(120deg, #fb923c, #ef4444);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 18rpx 32rpx rgba(249, 115, 22, 0.35);
}

.cta__secondary {
  flex: 1;
  background: rgba(255, 255, 255, 0.14);
  color: #e2e8f0;
  border-radius: 999rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.25);
}

.hero__stats {
  display: flex;
  justify-content: space-between;
  margin-top: 32rpx;
  background: rgba(15, 23, 42, 0.35);
  padding: 24rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(12rpx);
}

.stat {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.stat__value {
  font-size: 36rpx;
  font-weight: 600;
  color: #fef3c7;
}

.stat__label {
  font-size: 24rpx;
  color: rgba(248, 250, 252, 0.7);
}

.section__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.section__subtitle {
  font-size: 24rpx;
  color: #64748b;
}

.link-button {
  background: transparent;
  border: 2rpx solid #38bdf8;
  color: #0f172a;
  border-radius: 999rpx;
  padding: 0 24rpx;
}


.loop-card {
  padding: 28rpx;
  background: #f8fafc;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #e2e8f0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.loop-card--accent {
  background: #cffafe;
  border-color: #06b6d4;
}

.loop-card__tag {
  font-size: 24rpx;
  color: #0f172a;
  font-weight: 500;
}

.loop-card__title {
  font-size: 32rpx;
  font-weight: 600;
}

.loop-card__meta {
  font-size: 24rpx;
  color: #475569;
  display: flex;
  justify-content: space-between;
}

.loop-card__date {
  font-size: 22rpx;
  color: #94a3b8;
}

.history-card {
  background: #f1f5f9;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.history-card__title {
  display: flex;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.history-card__privacy {
  font-size: 24rpx;
  color: #38bdf8;
}

.history-card__meta {
  font-size: 24rpx;
  color: #475569;
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.history-card__meta--campus {
  color: #64748b;
}

.history-card__date {
  font-size: 22rpx;
  color: #94a3b8;
  display: flex;
  gap: 10rpx;
}

.history-card__date-split {
  opacity: 0.4;
}




.permission-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  z-index: 999;
}

.permission-dialog {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  box-shadow: 0 32rpx 56rpx rgba(15, 23, 42, 0.2);
}

.permission-dialog__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.permission-dialog__desc {
  margin: 24rpx 0 48rpx;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.5;
}

.permission-dialog__actions {
  display: flex;
  gap: 20rpx;
}

.permission-dialog__btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.18);
  color: #0f172a;
  font-size: 28rpx;
}

.permission-dialog__btn--primary {
  background: linear-gradient(120deg, #fb923c, #ef4444);
  color: #ffffff;
  box-shadow: 0 18rpx 32rpx rgba(249, 115, 22, 0.35);
}
