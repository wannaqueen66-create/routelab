<view class="page">
  <rlab-nav title="RouteLab" back="{{false}}"></rlab-nav>

  <view wx:if="{{!networkConnected}}" class="banner banner--offline">
    <text>当前网络不可用，轨迹会在恢复后自动同步</text>
  </view>

  <view class="tab-bar">
    <block wx:for="{{tabs}}" wx:key="key">
      <view
        class="tab-bar__item {{activeTab === item.key ? 'tab-bar__item--active' : ''}}"
        data-key="{{item.key}}"
        bindtap="handleTabChange"
      >
        <text class="tab-bar__icon">{{item.icon}}</text>
        <view class="tab-bar__label">{{item.label}}</view>
        <text wx:if="{{activeTab === item.key}}" class="tab-bar__desc">{{item.description}}</text>
      </view>
    </block>
  </view>

  <scroll-view scroll-y class="page__scroll" enable-back-to-top>
    <view wx:if="{{activeTab === 'home'}}" class="tab-content tab-content--home">
      <view class="home-fold">
      <view class="card card--weather">
        <view class="card__head">
          <text class="card__title">今日天气与建议</text>
          <button
            class="pill-button"
            size="mini"
            loading="{{weather.loading}}"
            bindtap="handleRefreshWeather"
          >
            刷新
          </button>
        </view>
        <view wx:if="{{weather.ready}}" class="weather">
          <view class="weather__headline">
            <text class="weather__temp">{{weather.temperature}}</text>
            <view class="weather__status">
              <text class="weather__text">{{weather.weatherText}}</text>
              <text class="weather__apparent" wx:if="{{weather.apparentTemperature}}">
                体感 {{weather.apparentTemperature}}
              </text>
            </view>
          </view>
          <view wx:if="{{weather.cityText}}" class="weather__location">
            <text>{{weather.cityText}}</text>
          </view>
          <view class="weather__advice">
            <view class="weather__advice-dot" style="background-color: {{weather.sportAdviceColor}}"></view>
            <text class="weather__advice-text">{{weather.suggestion}}</text>
          </view>
          <view class="weather__metrics">
            <view class="weather__metric">
              <text class="weather__metric-label">湿度</text>
              <text class="weather__metric-value">{{weather.humidityText}}</text>
            </view>
            <view class="weather__metric">
              <text class="weather__metric-label">风力</text>
              <text class="weather__metric-value">{{weather.windText}}</text>
            </view>
            <view class="weather__metric">
              <text class="weather__metric-label">空气</text>
              <text class="weather__metric-value">{{weather.airQualityText}}</text>
            </view>
          </view>
        </view>
        <view wx:elif="{{weather.loading}}" class="weather__empty">
          <text>正在定位并获取天气...</text>
        </view>
        <view wx:else class="weather__empty">
          <text>{{weather.error}}</text>
        </view>
      </view>

      <view class="card card--hero">
        <view class="hero__top">
          <view class="hero__titles">
            <text class="hero__eyebrow">今日概览</text>
            <text class="hero__title">开启校园轨迹</text>
            <text class="hero__desc">已积累 {{overview.todayDistance}} · {{overview.todayDuration}}</text>
          </view>
          <button class="btn btn--primary" bindtap="handleNavigateRecord">开始记录</button>
        </view>
        <view class="hero__stats">
          <view class="hero__stat">
            <text class="hero__stat-value">{{overview.todayDistance}}</text>
            <text class="hero__stat-label">今日里程</text>
            </view>
            <view class="hero__stat">
              <text class="hero__stat-value">{{overview.todayDuration}}</text>
              <text class="hero__stat-label">今日时长</text>
            </view>
            <view class="hero__stat">
              <text class="hero__stat-value">{{overview.totalCount}}</text>
              <text class="hero__stat-label">累计记录</text>
            </view>
            <view class="hero__stat">
              <text class="hero__stat-value">{{overview.totalDistance}}</text>
              <text class="hero__stat-label">累计里程</text>
            </view>
        </view>
      </view>
    </view>
    </view>

    <view wx:elif="{{activeTab === 'history'}}" class="tab-content tab-content--history">
      <view class="card card--history">
        <view class="history__header">
          <text class="card__title">历史轨迹</text>
          <button class="pill-button" size="mini" loading="{{historySyncing}}" bindtap="handleHistorySync">
            {{historySyncing ? '同步中' : '同步云端'}}
          </button>
        </view>
        <scroll-view scroll-x class="history__filters">
          <view class="history__filters-inner">
            <block wx:for="{{historyFilters}}" wx:key="key">
              <view
                class="chip {{historyActiveFilter === item.key ? 'chip--active' : ''}}"
                data-key="{{item.key}}"
                bindtap="handleHistoryFilterChange"
              >
                {{item.label}}
              </view>
            </block>
          </view>
        </scroll-view>
        <view wx:if="{{historyEmpty}}" class="history__empty">
          <text class="history__empty-title">暂未记录轨迹</text>
          <text class="history__empty-desc">开启一次运动，即可在此回顾完整轨迹</text>
          <button class="btn btn--primary" bindtap="handleNavigateRecord">立即记录</button>
        </view>
        <block wx:else>
          <block wx:for="{{historyRoutes}}" wx:key="id">
            <view
              class="history-route"
              data-id="{{item.id}}"
              bindtap="handleHistoryRouteTap"
              bindlongpress="handleHistoryRouteLongPress"
            >
              <view class="history-route__header">
                <view class="history-route__title-group">
                  <text class="history-route__title">{{item.title}}</text>
                  <view class="history-route__status" wx:if="{{item.syncPending}}">
                    <text class="history-route__status-icon">🔄</text>
                    <text class="history-route__status-text">{{item.syncStatusLabel}}</text>
                  </view>
                </view>
                <text class="history-route__privacy">{{item.privacyLabel}}</text>
              </view>
              <view class="history-route__meta">
                <text>{{item.distanceText}}</text>
                <text>·</text>
                <text>{{item.durationText}}</text>
                <text>·</text>
                <text>{{item.caloriesText}}</text>
              </view>
              <view class="history-route__path">
                <text>{{item.startLabel}}</text>
                <text class="history-route__arrow">→</text>
                <text>{{item.endLabel}}</text>
              </view>
              <view class="history-route__footer">
                <text>{{item.activityLabel}}</text>
                <text>｜{{item.weekLabel}} {{item.timeRange}}</text>
              </view>
              <view class="history-route__extra" wx:if="{{item.photosCount}}">
                <text>{{item.photosCount}} 张照片</text>
              </view>
              <view class="history-route__date">
                <text>{{item.startDate}}</text>
              </view>
            </view>
          </block>
        </block>
      </view>
    </view>

    <view wx:else class="tab-content tab-content--profile">
      <view class="profile-center">
        <view class="profile-card profile-card--identity">
          <view class="profile-card__header">
            <view class="profile-card__avatar">
              <image wx:if="{{userCard.avatarUrl}}" src="{{userCard.avatarUrl}}" mode="aspectFill"></image>
              <view
                wx:else
                class="profile-card__avatar-placeholder"
                style="background-color: {{userCard.avatarColor}}"
              >
                {{userCard.initial}}
              </view>
            </view>
            <view class="profile-card__info">
              <view class="profile-card__identity">
                <text class="profile-card__name">{{userCard.nickname}}</text>
                <text class="profile-card__status">{{userCard.shareStatus}}</text>
                <text class="profile-card__id">{{userCard.userIdLabel}}</text>
              </view>
              <view class="profile-card__points" bindtap="handleOpenBadgeWall">
                <text class="profile-card__points-label">当前积分</text>
                <text class="profile-card__points-value">{{userCard.totalPoints}}</text>
                <text class="profile-card__points-sub">{{userCard.badgeLabel}}</text>
              </view>
            </view>
          </view>
          <view class="profile-card__badge" bindtap="handleOpenBadgeWall">
            <text class="profile-card__badge-icon">{{userCard.badgeIcon}}</text>
            <view class="profile-card__badge-info">
              <text class="profile-card__badge-label">{{userCard.badgeLabel}}</text>
              <text class="profile-card__badge-sub">{{userCard.badgeUnlockedText}}</text>
            </view>
          </view>
          <view class="profile-card__hint-row" bindtap="handleOpenBadgeWall">
            <text class="profile-card__badge-hint">{{userCard.badgeNextHint}}</text>
            <text class="profile-card__badge-cta">查看勋章墙</text>
          </view>
        </view>

        <view class="profile-section profile-section--info">
          <view class="section-header">
            <text class="section-title">个人信息</text>
            <text class="section-subtitle">完善资料可获得更准确的运动统计</text>
          </view>
          <view class="info-list">
            <block wx:for="{{userCard.personalInfo}}" wx:key="key">
              <view class="info-row">
                <text class="info-row__label">{{item.label}}</text>
                <text class="info-row__value">{{item.value}}</text>
              </view>
            </block>
          </view>
          <button class="btn btn--primary profile-section__cta" bindtap="handleCompleteProfile">
            完善个人信息
          </button>
        </view>

        <view class="profile-section profile-section--sync">
          <view class="section-header">
            <text class="section-title">同步状态</text>
            <text class="section-subtitle">手动同步可立即上传未同步数据</text>
          </view>
          <view class="sync-summary">
            <view class="sync-summary__item">
              <text class="sync-summary__value">{{syncInfo.pending}}</text>
              <text class="sync-summary__label">待同步</text>
            </view>
            <view class="sync-summary__item">
              <text class="sync-summary__value">{{syncInfo.synced}}</text>
              <text class="sync-summary__label">已同步</text>
            </view>
            <view class="sync-summary__item">
              <text class="sync-summary__value">{{syncInfo.deleted}}</text>
              <text class="sync-summary__label">已屏蔽</text>
            </view>
          </view>
          <view class="sync-meta">
            <text>上次同步：{{syncInfo.lastSyncText}}</text>
          </view>
          <button class="btn btn--ghost" loading="{{syncBusy}}" bindtap="handleManualSync">
            {{syncBusy ? '同步中...' : '手动同步'}}
          </button>
        </view>

        <view class="profile-section profile-section--settings">
          <view class="settings-row">
            <view class="settings-row__texts">
              <text class="settings-row__title">默认隐私</text>
              <text class="settings-row__desc">{{userCard.privacyDescription}}</text>
            </view>
            <switch checked="{{userCard.defaultPublic}}" bindchange="handlePrivacySwitchChange"></switch>
          </view>
          <view class="settings-divider"></view>
          <view class="settings-row settings-row--link" bindtap="handleOpenAbout">
            <view class="settings-row__texts">
              <text class="settings-row__title">关于 RouteLab</text>
              <text class="settings-row__desc">了解应用版本与协议信息</text>
            </view>
            <text class="settings-row__link-text">查看</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="announcement-mask" wx:if="{{announcementModalVisible}}">
    <view class="announcement-dialog">
      <view class="announcement-dialog__header">
        <text class="announcement-dialog__title">
          {{announcementModal.title || '系统公告'}}
        </text>
        <text
          wx:if="{{announcementModal.publishAtText}}"
          class="announcement-dialog__time"
        >
          {{announcementModal.publishAtText}}
        </text>
      </view>
      <scroll-view scroll-y class="announcement-dialog__body">
        <text class="announcement-dialog__content">
          {{announcementModal.body}}
        </text>
      </scroll-view>
      <view class="announcement-dialog__actions">
        <button
          wx:if="{{!announcementModal.forceRead}}"
          class="announcement-dialog__btn"
          bindtap="handleSkipAnnouncement"
        >
          稍后再看
        </button>
        <button
          wx:if="{{announcementModal.linkUrl}}"
          class="announcement-dialog__btn"
          bindtap="handleAnnouncementLinkTap"
        >
          查看详情
        </button>
        <button
          class="announcement-dialog__btn announcement-dialog__btn--primary"
          bindtap="handleConfirmAnnouncement"
        >
          我已知晓
        </button>
      </view>
    </view>
  </view>

  <view class="permission-mask" wx:if="{{showLocationPrompt}}">
    <view class="permission-dialog">
      <text class="permission-dialog__title">需要开启定位权限</text>
      <text class="permission-dialog__desc">
        RouteLab 需要使用定位以获取天气建议，并准确记录校园轨迹，请允许使用位置信息。
      </text>
      <view class="permission-dialog__actions">
        <button
          class="permission-dialog__btn permission-dialog__btn--primary"
          bindtap="handleRequestLocationAuthorize"
        >
          去授权
        </button>
        <button class="permission-dialog__btn" bindtap="handleOpenLocationSetting">
          打开设置
        </button>
      </view>
    </view>
  </view>
</view>
