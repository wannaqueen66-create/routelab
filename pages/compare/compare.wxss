.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-page-bg);
  color: var(--color-text-primary);
  transition: background 0.3s ease, color 0.3s ease;
}

.page__scroll {
  flex: 1;
  padding: 24rpx 32rpx 64rpx;
  box-sizing: border-box;
}

.summary {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.summary-card {
  flex: 1;
  padding: 28rpx;
  border-radius: 24rpx;
  background: var(--color-surface-muted);
  color: var(--color-text-primary);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  transition: background 0.3s ease, color 0.3s ease;
}

.summary-card--active {
  background: #38bdf8;
  color: var(--color-text-primary);
  box-shadow: 0 16rpx 32rpx rgba(56, 189, 248, 0.3);
}

.summary-card__title {
  font-size: 28rpx;
  font-weight: 600;
}

.summary-card__metric {
  font-size: 40rpx;
  font-weight: 700;
}

.summary-card__sub,
.summary-card__count {
  font-size: 24rpx;
  opacity: 0.8;
}

.insights {
  background: var(--color-surface);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.05);
  margin-bottom: 32rpx;
  transition: background 0.3s ease, color 0.3s ease;
}

.insights__title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--color-text-primary);
}

.insights__item {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 12rpx 0;
  border-bottom: 2rpx dashed rgba(148, 163, 184, 0.4);
}

.insights__item:last-child {
  border-bottom: none;
}

.level {
  background: var(--color-surface);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.05);
  transition: background 0.3s ease, color 0.3s ease;
}

.level__head {
  margin-bottom: 20rpx;
}

.level__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.level__desc {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}

.route-card {
  background: var(--color-surface-muted);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  border: 2rpx solid var(--color-border);
  transition: background 0.3s ease, border-color 0.3s ease;
}

.route-card__title {
  font-size: 30rpx;
  font-weight: 600;
}

.route-card__meta,
.route-card__footer {
  display: flex;
  gap: 10rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.route-card__footer {
  justify-content: space-between;
  color: var(--color-text-tertiary);
}

.empty {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  padding: 24rpx 0;
}

/* ── Dark mode overrides ── */
.dark .summary-card--active {
  background: #0284c7;
  color: #ffffff;
  box-shadow: 0 16rpx 32rpx rgba(2, 132, 199, 0.35);
}

.dark .insights {
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.15);
}

.dark .level {
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.15);
}

.dark .insights__item {
  border-bottom-color: rgba(148, 163, 184, 0.15);
}
