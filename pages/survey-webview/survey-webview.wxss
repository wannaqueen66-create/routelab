.survey-webview-error {
  min-height: 100vh;
  padding: 120rpx 48rpx;
  box-sizing: border-box;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.survey-webview-error__title {
  font-size: 40rpx;
  line-height: 1.4;
  color: #0f172a;
  font-weight: 700;
}

.survey-webview-error__desc {
  margin-top: 20rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #475569;
}

.survey-webview-error__btn {
  margin-top: 40rpx;
  min-width: 320rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 88rpx;
}
