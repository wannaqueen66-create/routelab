<web-view wx:if="{{ready}}" src="{{url}}" binderror="handleWebViewError"></web-view>

<view wx:else class="survey-webview-error">
  <text class="survey-webview-error__title">问卷页面无法打开</text>
  <text class="survey-webview-error__desc">{{error}}</text>
  <button class="survey-webview-error__btn" bindtap="handleNavigateBack">返回上一页</button>
</view>
