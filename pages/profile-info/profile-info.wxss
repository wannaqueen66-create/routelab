.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(
    --gradient-page,
    linear-gradient(180deg, var(--color-page-bg) 0%, var(--color-page-bg-strong) 100%)
  );
}

.page__scroll {
  flex: 1;
  padding: 24rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.section {
  background: var(--color-surface);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(18, 38, 77, 0.08);
  transition: background 0.3s ease;
}

.section--avatar {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section__label {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.section__label-meta {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-tertiary);
}

.section__hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.section__error {
  font-size: 26rpx;
  color: #d14343;
}

.avatar-picker {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-preview {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-surface-muted);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-preview__image {
  width: 100%;
  height: 100%;
}

.avatar-preview__placeholder {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

.avatar-picker__button {
  flex-shrink: 0;
  min-width: 200rpx;
  background: linear-gradient(135deg, #2f6bff, #1f54ff);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.avatar-picker__button[disabled='true'] {
  opacity: 0.6;
}

.avatar-picker__fallback {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  line-height: 1.6;
}

.nickname-input {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  background: var(--color-surface-muted);
}

.nickname-input:focus {
  box-shadow: 0 0 0 4rpx var(--color-primary-soft);
}

.radio-group {
  margin-top: 24rpx;
  display: flex;
  gap: 40rpx;
  flex-wrap: wrap;
}

.radio-group__option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.radio-group__text {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.picker {
  margin-top: 24rpx;
}

.picker__display {
  padding: 24rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  background: var(--color-surface-muted);
}

.picker__display:focus {
  box-shadow: 0 0 0 4rpx var(--color-primary-soft);
}

.picker__display--placeholder {
  color: var(--color-text-tertiary);
}

.section--metrics {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field__label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.field__input {
  padding: 24rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  background: var(--color-surface-muted);
}

.field__input:focus {
  box-shadow: 0 0 0 4rpx var(--color-primary-soft);
}

.save-button {
  width: 100%;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2f6bff, #1f54ff);
  color: #ffffff;
  font-size: 32rpx;
  padding: 24rpx 0;
  box-shadow: 0 12rpx 24rpx rgba(47, 73, 209, 0.24);
}

.save-button[disabled='true'] {
  opacity: 0.6;
}

/* Dark mode overrides */
.dark .section {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.dark .avatar-preview {
  background: var(--color-surface-muted);
}

.dark .save-button {
  box-shadow: 0 12rpx 24rpx rgba(47, 73, 209, 0.4);
}
