.rlab-progress {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rlab-progress__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.rlab-progress__label {
  font-weight: 500;
}

.rlab-progress__value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.rlab-progress__bar {
  width: 100%;
  height: 18rpx;
  border-radius: var(--radius-pill);
  background: rgba(31, 42, 68, 0.08);
  overflow: hidden;
}

.rlab-progress__fill {
  height: 100%;
  border-radius: inherit;
  background: var(--gradient-progress-primary);
  transition: width var(--transition-base);
}

.rlab-progress__fill--accent {
  background: var(--gradient-progress-accent);
}

.rlab-progress__fill--energy {
  background: var(--gradient-progress-energy);
}

.rlab-progress__fill--info {
  background: linear-gradient(90deg, #54c4ff, #5f8bff);
}

.rlab-progress__meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.rlab-progress__goal {
  font-weight: 500;
}

.rlab-progress__hint {
  text-align: right;
}
