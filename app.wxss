/** RouteLab global theme (UTF-8, no BOM) **/
:root {
  --color-page-bg: #f8fafc;
  --color-page-bg-strong: #eef2f6;
  --color-surface: #ffffff;
  --color-surface-muted: #f4f7fb;
  --color-primary: #2f6bff;
  --color-primary-strong: #1f54ff;
  --color-primary-soft: rgba(47, 107, 255, 0.12);
  --color-accent: #42c79f;
  --color-accent-soft: rgba(66, 199, 159, 0.15);
  --color-warning: #ff9f43;
  --color-danger: #ff6b6b;
  --color-text-primary: #1f2a44;
  --color-text-secondary: #5c6c8c;
  --color-text-tertiary: #8c99b0;
  --color-border: rgba(31, 42, 68, 0.08);
  --shadow-card: 0 22rpx 48rpx rgba(15, 23, 42, 0.08);
  --shadow-card-hover: 0 32rpx 64rpx rgba(15, 23, 42, 0.12);
  --shadow-floating: 0 24rpx 48rpx rgba(0, 0, 0, 0.15);
  --radius-card: 32rpx;
  --radius-panel: 40rpx;
  --radius-pill: 999rpx;
  --transition-base: 0.3s ease;
  --gradient-hero: linear-gradient(135deg, #f7faff, #eef4ff);
  --gradient-progress-primary: linear-gradient(90deg, #3d7bff, #8c5bff);
  --gradient-progress-accent: linear-gradient(90deg, #42c79f, #52e4b3);
  --gradient-progress-energy: linear-gradient(90deg, #ff8a5c, #ff5f6d);
  --gradient-page: linear-gradient(180deg, #f8fafc 0%, #eef2f6 100%);
  --gradient-card-accent: linear-gradient(
    135deg,
    rgba(47, 107, 255, 0.08) 0%,
    rgba(66, 199, 159, 0.05) 100%
  );
  --color-border-soft: rgba(31, 42, 68, 0.05);
  --overlay-scrim: rgba(15, 23, 42, 0.5);
  --spacing-page: 32rpx;
  --spacing-card: 28rpx;
  --spacing-section-gap: 24rpx;
  --spacing-item-gap: 16rpx;
}

/* ── Dark mode overrides ── */
.dark {
  --color-page-bg: #0f172a;
  --color-page-bg-strong: #0a1128;
  --color-surface: #1e293b;
  --color-surface-muted: #162035;
  --color-primary: #60a5fa;
  --color-primary-strong: #3b82f6;
  --color-primary-soft: rgba(96, 165, 250, 0.15);
  --color-accent: #34d399;
  --color-accent-soft: rgba(52, 211, 153, 0.18);
  --color-warning: #fbbf24;
  --color-danger: #f87171;
  --color-text-primary: #f1f5f9;
  --color-text-secondary: #94a3b8;
  --color-text-tertiary: #64748b;
  --color-border: rgba(248, 250, 252, 0.08);
  --color-border-soft: rgba(248, 250, 252, 0.05);
  --shadow-card: 0 22rpx 48rpx rgba(0, 0, 0, 0.25);
  --shadow-card-hover: 0 32rpx 64rpx rgba(0, 0, 0, 0.35);
  --shadow-floating: 0 24rpx 48rpx rgba(0, 0, 0, 0.4);
  --radius-card: 32rpx;
  --gradient-hero: linear-gradient(135deg, #1e293b, #162035);
  --gradient-page: linear-gradient(180deg, #0f172a 0%, #0a1128 100%);
  --gradient-card-accent: linear-gradient(
    135deg,
    rgba(96, 165, 250, 0.1) 0%,
    rgba(52, 211, 153, 0.06) 100%
  );
  --gradient-progress-primary: linear-gradient(90deg, #60a5fa, #a78bfa);
  --gradient-progress-accent: linear-gradient(90deg, #34d399, #6ee7b7);
  --gradient-progress-energy: linear-gradient(90deg, #fb923c, #f87171);
  --overlay-scrim: rgba(0, 0, 0, 0.6);
}

page {
  background: var(--gradient-page, var(--color-page-bg));
  color: var(--color-text-primary);
  font-size: 14px;
  line-height: 1.6;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft Yahei', sans-serif;
}

view,
text,
image,
button {
  box-sizing: border-box;
}

button {
  background: transparent;
  border: none;
  color: inherit;
  transition: background var(--transition-base), color var(--transition-base), transform var(--transition-base);
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(
    --gradient-page,
    linear-gradient(180deg, var(--color-page-bg) 0%, var(--color-page-bg-strong) 100%)
  );
}

.page__scroll {
  flex: 1;
  padding: 32rpx;
}

.card {
  background: var(--color-surface);
  border-radius: var(--radius-card);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  transition: transform var(--transition-base), box-shadow var(--transition-base), background var(--transition-base);
}

.card--interactive:active,
.card--interactive:focus {
  transform: translateY(-6rpx);
  box-shadow: var(--shadow-card-hover);
}

.card--hero {
  background: var(--gradient-hero);
  color: var(--color-text-primary);
}

.card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.card__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.card__desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.btn {
  padding: 24rpx 32rpx;
  border-radius: var(--radius-pill);
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: box-shadow var(--transition-base), transform var(--transition-base), background var(--transition-base), color var(--transition-base);
}

.btn--primary {
  background: linear-gradient(125deg, #2f6bff, #1f54ff);
  color: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(31, 84, 255, 0.28);
}

.btn--primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 10rpx 26rpx rgba(31, 84, 255, 0.2);
}

.btn--accent {
  background: linear-gradient(125deg, #48cfb1, #2fb485);
  color: #0f2a29;
  box-shadow: 0 18rpx 36rpx rgba(72, 207, 177, 0.25);
}

.btn--ghost {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid rgba(47, 107, 255, 0.4);
}

.btn--ghost:active {
  background: rgba(47, 107, 255, 0.08);
}

.pill-button {
  padding: 16rpx 28rpx;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  border: 1px solid rgba(47, 107, 255, 0.25);
  color: var(--color-primary);
  background: var(--color-surface);
  box-shadow: 0 6rpx 14rpx rgba(31, 84, 255, 0.08);
}

.link-button {
  padding: 0;
  color: var(--color-primary);
  font-size: 26rpx;
  text-decoration: none;
}

.banner {
  border-radius: var(--radius-card);
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  box-shadow: var(--shadow-card);
}

.banner--offline {
  background: rgba(255, 159, 67, 0.12);
  color: var(--color-warning);
}

.chip {
  padding: 12rpx 28rpx;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: rgba(31, 42, 68, 0.06);
  border: 1px solid rgba(31, 42, 68, 0.08);
  transition: border var(--transition-base), color var(--transition-base), background var(--transition-base);
}

.chip--active {
  border-color: rgba(47, 107, 255, 0.3);
  background: rgba(47, 107, 255, 0.12);
  color: var(--color-primary);
}

.progress {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.progress__bar {
  width: 100%;
  height: 18rpx;
  border-radius: var(--radius-pill);
  background: rgba(31, 42, 68, 0.08);
  overflow: hidden;
}

.progress__fill {
  height: 100%;
  border-radius: inherit;
  background: var(--gradient-progress-primary);
  transition: width var(--transition-base);
}

.progress__fill--accent {
  background: var(--gradient-progress-accent);
}

.progress__fill--energy {
  background: var(--gradient-progress-energy);
}

.section {
  background: var(--color-surface);
  border-radius: var(--radius-card);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.section__desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.divider {
  height: 2rpx;
  background: rgba(31, 42, 68, 0.08);
  margin: 16rpx 0;
}

/* ── Dark mode overrides for global components ── */
.dark .btn--primary {
  background: linear-gradient(125deg, #3b82f6, #2563eb);
  box-shadow: 0 18rpx 36rpx rgba(59, 130, 246, 0.3);
}

.dark .btn--accent {
  background: linear-gradient(125deg, #34d399, #059669);
  color: #f0fdf4;
  box-shadow: 0 18rpx 36rpx rgba(52, 211, 153, 0.25);
}

.dark .btn--ghost {
  border-color: rgba(96, 165, 250, 0.3);
  color: var(--color-primary);
}

.dark .btn--ghost:active {
  background: rgba(96, 165, 250, 0.1);
}

.dark .btn--danger {
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: #fff;
}

.dark .pill-button {
  border-color: rgba(96, 165, 250, 0.2);
  background: var(--color-surface);
  color: var(--color-primary);
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, 0.2);
}

.dark .chip {
  background: rgba(248, 250, 252, 0.06);
  border-color: rgba(248, 250, 252, 0.08);
  color: var(--color-text-secondary);
}

.dark .chip--active {
  background: rgba(96, 165, 250, 0.15);
  border-color: rgba(96, 165, 250, 0.3);
  color: var(--color-primary);
}

.dark .progress__bar {
  background: rgba(248, 250, 252, 0.08);
}

.dark .divider {
  background: rgba(248, 250, 252, 0.06);
}

.dark .banner--offline {
  background: rgba(251, 191, 36, 0.12);
  color: var(--color-warning);
}

/* ── Micro-interactions ── */
.btn:active {
  transform: translateY(2rpx) scale(0.98);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.fade-in {
  animation: fadeIn 0.3s ease forwards;
}

.shimmer {
  background: linear-gradient(90deg,
    var(--color-surface-muted) 25%,
    var(--color-surface) 50%,
    var(--color-surface-muted) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.text-center {
  text-align: center;
}

.text-secondary {
  color: var(--color-text-secondary);
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}
