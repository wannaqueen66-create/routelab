# Version control
.git
.gitignore

# Dependencies (will be installed in container)
node_modules
*/node_modules
server/node_modules
web/node_modules

# Build artifacts that shouldn't be in image
web/dist
server/dist

# Development files
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# Environment files
.env
.env.*
!.env.example

# IDE/Editor
.idea
.vscode
*.swp
*.swo

# Test files
*.test.js
*.spec.js
**/test/
**/tests/
**/__tests__/
coverage/

# Data directories (mounted as volumes)
server/data
data/
uploads/
backups/

# Documentation (not needed in container)
*.md
!DEPLOYMENT.md

# Local development
server/.env
web/.env
