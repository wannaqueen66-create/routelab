PORT=4000
DATABASE_URL=postgres://user:password@localhost:5432/routelab
PGSSLMODE=disable
JWT_SECRET=replace-with-secure-value
JWT_EXPIRES_IN=7d
STORAGE_LOCAL_PATH=/data/uploads
STORAGE_BASE_URL=https://routelab.qzz.io/static/uploads
WECHAT_APPID=your-miniprogram-appid
WECHAT_SECRET=your-miniprogram-secret
PUBLIC_ROUTE_LIMIT=24

# Weather providers (priority: 1 QWeather, 2 AMap, 3 Open-Meteo)
# Example: API_HOST=xxxxx.qweatherapi.com
API_HOST=
API_KEY=
# Legacy fallback (optional)
# QWEATHER_API_KEY=
# QWEATHER_BASE_URL=https://devapi.qweather.com/v7
OPEN_METEO_WEATHER_BASE=https://api.open-meteo.com/v1/forecast
OPEN_METEO_AIR_BASE=https://air-quality-api.open-meteo.com/v1/air-quality
WEATHER_USER_AGENT=RouteLabServer/1.0 (+https://routelab.qzz.io)

ADMIN_USER=admin
# ADMIN_PASSWORD 或 ADMIN_PASSWORD_HASH 二选一配置
ADMIN_PASSWORD=change-me-soon
# ADMIN_PASSWORD_HASH=$2a$10$examplehashvaluereplace
BACKUP_STORAGE_PATH=/data/backups
ADMIN_EXPORT_LIMIT=2000
ADMIN_PAGE_SIZE=25

# Map / geocode providers (priority: 1 AMap, 2 OpenStreetMap)
AMAP_WEB_KEY=
AMAP_TIMEOUT_MS=6500
GEOCODE_CACHE_TTL_MS=600000
GEOCODE_CACHE_GRID_SIZE=0.001
GEOCODE_OSM_BASE_URL=https://nominatim.openstreetmap.org
GEOCODE_OSM_USER_AGENT=RouteLabServer/1.0 (+https://routelab.qzz.io)
