# ==========================
# RouteLab Cloud Environment
# ==========================

# ===== Database =====
POSTGRES_DB=routelab
POSTGRES_USER=routelab
POSTGRES_PASSWORD=ChangeThisToAStrongPassword_8uVw2!

# ===== API & Nginx =====
API_PORT=8080
NGINX_PORT_HTTP=80
NGINX_PORT_HTTPS=443

# ===== Security =====
JWT_SECRET=ChangeThisToARandomHex_64chars

# ===== External URLs =====
STORAGE_BASE_URL=https://routelab.qzz.io/static/uploads

# ===== Dashboard Build (optional) =====
# Overrides the API base URL baked into the web build. Keep "/api" when Nginx
# proxies the API under the same domain.
VITE_API_BASE_URL=/api

# ===== WeChat Mini Program =====
WECHAT_APPID=wx_your_real_appid
WECHAT_SECRET=your_real_app_secret

# ===== Admin Account (Web Dashboard) =====
ADMIN_USER=admin
# During development you can use a plaintext password. Remove before production.
# ADMIN_PASSWORD=YourStrongAdminPassword
# Preferred for production: store only a bcrypt hash (generate with bcrypt-cli or an online tool).
# ADMIN_PASSWORD_HASH=$2b$12$PUT_YOUR_BCRYPT_HASH_HERE

# ===== Weather Providers =====
# 1. QWeather (HeWeather) – China focused, needs dedicated API host/key
# Example: API_HOST=xxxxx.qweatherapi.com
API_HOST=
API_KEY=
# Legacy fallback (optional)
# QWEATHER_API_KEY=
# QWEATHER_BASE_URL=https://devapi.qweather.com/v7

# 2. AMap Weather – uses the same Web Service key as geocoding
AMAP_WEB_KEY=
AMAP_TIMEOUT_MS=6500

# 3. Open-Meteo – free, no key required (kept as fallback)
OPEN_METEO_WEATHER_BASE=https://api.open-meteo.com/v1/forecast
OPEN_METEO_AIR_BASE=https://air-quality-api.open-meteo.com/v1/air-quality

# Shared UA for all outbound weather/geocode HTTP requests
WEATHER_USER_AGENT=RouteLabServer/1.0 (+https://routelab.qzz.io)

# ===== Map / Geocode Providers =====
# 1. AMap Web Service (GCJ‑02) – used for /api/geocode/* and reverse geocode
GEOCODE_CACHE_TTL_MS=600000
GEOCODE_CACHE_GRID_SIZE=0.001

# 2. OpenStreetMap Nominatim – fallback when AMap is unavailable
GEOCODE_OSM_BASE_URL=https://nominatim.openstreetmap.org
GEOCODE_OSM_USER_AGENT=RouteLabServer/1.0 (+https://routelab.qzz.io)

# ===== Optional Server Settings =====
BACKUP_STORAGE_PATH=./data/backups
ADMIN_EXPORT_LIMIT=2000
ADMIN_PAGE_SIZE=25
