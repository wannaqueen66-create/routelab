# ==========================
# RouteLab Cloud Environment
# ==========================

# ===== Database =====
POSTGRES_DB=routelab
POSTGRES_USER=routelab
POSTGRES_PASSWORD=ChangeThisToAStrongPassword_8uVw2!

# ===== API & Nginx =====
API_PORT=8080
NGINX_PORT_HTTP=80
NGINX_PORT_HTTPS=443

# ===== Security =====
JWT_SECRET=ChangeThisToARandomHex_64chars

# ===== External URLs =====
STORAGE_BASE_URL=https://routelab.qzz.io/static/uploads

# ===== Dashboard Build (optional) =====
# Overrides the API base URL baked into the web build. Keep "/api" when Nginx
# proxies the API under the same domain.
VITE_API_BASE_URL=/api

# ===== WeChat Mini Program =====
WECHAT_APPID=wx_your_real_appid
WECHAT_SECRET=your_real_app_secret

# ===== Admin Account (Web Dashboard) =====
ADMIN_USER=admin
# During development you can use a plaintext password. Remove before production.
# ADMIN_PASSWORD=YourStrongAdminPassword
# Preferred for production: store only a bcrypt hash (generate with bcrypt-cli or an online tool).
# ADMIN_PASSWORD_HASH=$2b$12$PUT_YOUR_BCRYPT_HASH_HERE

# ===== Optional =====
WEATHER_USER_AGENT=RouteLab/1.0 (+https://routelab.qzz.io)
BACKUP_STORAGE_PATH=./data/backups
ADMIN_EXPORT_LIMIT=2000
ADMIN_PAGE_SIZE=25
